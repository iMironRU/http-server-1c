///////////////////////////////////////////////////////////////////////////////
// http_SwaggerГенератор
//
// Генерация OpenAPI 3.0 спецификации из единого источника правды -
// реестров методов JRPC и маршрутов REST (см. http_СерверСлужебныйПовтИсп).
//
// Главная точка - СформироватьOpenAPI(БазовыйURL): возвращает структуру,
// сериализуемую в swagger.json.
//
// Логика:
//   - Каждый REST-маршрут описывается как отдельный path с уточнённым методом.
//   - JRPC-методы описываются как один path "/jrpc/call" (POST) с oneOf
//     по requestBody: каждый метод - вариант с фиксированным literal в "method".
//   - Схемы параметров переводятся из формата http_СерверКлиентСервер
//     в OpenAPI Schema Object.
//   - SecuritySchemes: Basic, Bearer, APIKey - по умолчанию доступны все.
///////////////////////////////////////////////////////////////////////////////

#Область ПрограммныйИнтерфейс

// Формирует структуру для записи в swagger.json.
//
// Параметры:
//  БазовыйURL - Строка - префикс сервера для секции "servers" (например
//               "http://host/base/hs"). Если пустой - "servers" не заполняется.
//
// Возвращаемое значение:
//  Структура - корневой объект OpenAPI 3.0.
//
Функция СформироватьOpenAPI(БазовыйURL = "") Экспорт

	Spec = Новый Структура;
	Spec.Вставить("openapi", "3.0.0");
	Spec.Вставить("info",    СформироватьInfo());

	Если Не ПустаяСтрока(БазовыйURL) Тогда
		Серверы = Новый Массив;
		СерверЭлемент = Новый Структура;
		СерверЭлемент.Вставить("url", БазовыйURL);
		Серверы.Добавить(СерверЭлемент);
		Spec.Вставить("servers", Серверы);
	КонецЕсли;

	Spec.Вставить("paths",      СформироватьPaths());
	Spec.Вставить("components", СформироватьComponents());
	Spec.Вставить("tags",       СформироватьTags());

	Возврат Spec;

КонецФункции

// Сериализует spec в строку JSON.
Функция СпецификацияВJSON(Spec) Экспорт

	ЗаписьJSON = Новый ЗаписьJSON;
	ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто, "  ");
	ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписи);
	ЗаписатьJSON(ЗаписьJSON, Spec);
	Возврат ЗаписьJSON.Закрыть();

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область КорневыеСекции

Функция СформироватьInfo()

	Info = Новый Структура;
	Info.Вставить("title",       "http_HTTPСервер: " + Метаданные.Имя);
	Info.Вставить("description", "OpenAPI спецификация HTTP-сервисов расширения. Методы JRPC и REST-маршруты собраны автообнаружением из HTTPПодсистема-модулей.");
	Info.Вставить("version",     Строка(Метаданные.Версия));
	Возврат Info;

КонецФункции

Функция СформироватьPaths()

	// Соответствие, а не Структура: ключи путей содержат "/" и "{...}" -
	// невалидные имена для Структуры.
	Paths = Новый Соответствие;

	// REST-маршруты из реестра
	ДобавитьRESTМаршруты(Paths);

	// JRPC - один путь /jrpc/call с oneOf по методам
	ДобавитьJRPCПуть(Paths);

	Возврат Paths;

КонецФункции

Функция СформироватьComponents()

	Components = Новый Структура;
	Components.Вставить("securitySchemes", СформироватьSecuritySchemes());
	Components.Вставить("schemas",         СформироватьСхемыJRPC());
	Возврат Components;

КонецФункции

Функция СформироватьTags()

	Tags = Новый Массив;

	JRPCTag = Новый Структура;
	JRPCTag.Вставить("name",        "JRPC");
	JRPCTag.Вставить("description", "Методы JSON-RPC 2.0, доступные через /jrpc/call");
	Tags.Добавить(JRPCTag);

	RESTTag = Новый Структура;
	RESTTag.Вставить("name",        "REST");
	RESTTag.Вставить("description", "REST-эндпоинты прикладных HTTPПодсистем");
	Tags.Добавить(RESTTag);

	Возврат Tags;

КонецФункции

Функция СформироватьSecuritySchemes()

	Схемы = Новый Структура;

	Basic = Новый Структура;
	Basic.Вставить("type",   "http");
	Basic.Вставить("scheme", "basic");
	Схемы.Вставить("Basic", Basic);

	Bearer = Новый Структура;
	Bearer.Вставить("type",         "http");
	Bearer.Вставить("scheme",       "bearer");
	Bearer.Вставить("bearerFormat", "JWT");
	Схемы.Вставить("Bearer", Bearer);

	APIKey = Новый Структура;
	APIKey.Вставить("type", "apiKey");
	APIKey.Вставить("in",   "header");
	APIKey.Вставить("name", "X-API-Key");
	Схемы.Вставить("APIKey", APIKey);

	Возврат Схемы;

КонецФункции

#КонецОбласти

#Область REST

Процедура ДобавитьRESTМаршруты(Paths)

	Реестр = http_СерверСлужебныйПовтИсп.МаршрутыHTTP();

	Для Каждого ЭлементРеестра Из Реестр Цикл
		Маршрут = ЭлементРеестра.Значение;

		// Если путь уже добавлен другим методом - расширяем
		PathItem = Paths.Получить(Маршрут.ШаблонURL);
		Если PathItem = Неопределено Тогда
			PathItem = Новый Структура;
			Paths.Вставить(Маршрут.ШаблонURL, PathItem);
		КонецЕсли;

		Операция = СформироватьОперациюREST(Маршрут);
		PathItem.Вставить(НРег(Маршрут.HTTPМетод), Операция);

	КонецЦикла;

КонецПроцедуры

Функция СформироватьОперациюREST(Маршрут)

	Операция = Новый Структура;
	Операция.Вставить("tags",        ОдинЭлементВМассиве("REST"));
	Операция.Вставить("summary",     Маршрут.Описание);
	Операция.Вставить("operationId", СформироватьOperationId(Маршрут));

	Параметры = Новый Массив;
	ДобавитьПараметрыИзСхемы(Параметры, Маршрут.СхемаПути,  "path");
	ДобавитьПараметрыИзСхемы(Параметры, Маршрут.СхемаQuery, "query");
	Операция.Вставить("parameters", Параметры);

	Если Маршрут.HTTPМетод = "POST" Или Маршрут.HTTPМетод = "PUT" Или Маршрут.HTTPМетод = "PATCH" Тогда
		Если Маршрут.СхемаТела <> Неопределено Тогда
			Операция.Вставить("requestBody", СформироватьRequestBody(Маршрут.СхемаТела));
		КонецЕсли;
	КонецЕсли;

	Операция.Вставить("responses", СформироватьСтандартныеОтветы());

	Безопасность = СформироватьSecurityИзМаршрута(Маршрут.Аутентификация);
	Если Безопасность <> Неопределено Тогда
		Операция.Вставить("security", Безопасность);
	КонецЕсли;

	Возврат Операция;

КонецФункции

Функция СформироватьOperationId(Маршрут)

	Чистый = СтрЗаменить(Маршрут.ШаблонURL, "/", "_");
	Чистый = СтрЗаменить(Чистый, "{", "");
	Чистый = СтрЗаменить(Чистый, "}", "");
	Чистый = СтрЗаменить(Чистый, " ", "_");
	Возврат Маршрут.Сервис + НРег(Маршрут.HTTPМетод) + Чистый;

КонецФункции

#КонецОбласти

#Область JRPC

Процедура ДобавитьJRPCПуть(Paths)

	Методы = http_СерверСлужебныйПовтИсп.МетодыJRPC();
	Если Методы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	PathItem = Новый Структура;
	Операция = Новый Структура;

	Операция.Вставить("tags",        ОдинЭлементВМассиве("JRPC"));
	Операция.Вставить("summary",     "JSON-RPC 2.0 endpoint");
	Операция.Вставить("description", СформироватьОписаниеJRPC(Методы));
	Операция.Вставить("operationId", "jrpc_call");

	RequestBody = Новый Структура;
	RequestBody.Вставить("required", Истина);
	// Соответствие для content: ключ "application/json" содержит "/"
	ContentJSON = Новый Соответствие;
	JsonContent = Новый Структура;
	JsonContent.Вставить("schema", СформироватьСхемуJRPCRequest());
	ContentJSON.Вставить("application/json", JsonContent);
	RequestBody.Вставить("content", ContentJSON);
	Операция.Вставить("requestBody", RequestBody);

	Операция.Вставить("responses", СформироватьОтветыJRPC());

	PathItem.Вставить("post", Операция);
	Paths.Вставить("/jrpc/call", PathItem);

КонецПроцедуры

Функция СформироватьОписаниеJRPC(Методы)

	Строки = Новый Массив;
	Строки.Добавить("Зарегистрированные методы:");
	Строки.Добавить("");
	Строки.Добавить("| Метод | Описание | Версия | Устарел |");
	Строки.Добавить("|-------|----------|--------|---------|");

	Для Каждого Элемент Из Методы Цикл
		Метод = Элемент.Значение;
		Описание = ?(ПустаяСтрока(Метод.Описание), "-", Метод.Описание);
		Версия   = ?(ПустаяСтрока(Метод.Версия),   "-", Метод.Версия);
		Устарел  = ?(Метод.Устарел, "✓", "");
		Строки.Добавить("| `" + Метод.Имя + "` | " + Описание + " | " + Версия + " | " + Устарел + " |");
	КонецЦикла;

	Возврат СтрСоединить(Строки, Символы.ПС);

КонецФункции

Функция СформироватьСхемуJRPCRequest()

	Схема = Новый Структура;
	Схема.Вставить("type", "object");
	Схема.Вставить("required", СтрокаВМассив("jsonrpc,method"));

	Свойства = Новый Структура;

	JsonrpcСвойство = Новый Структура;
	JsonrpcСвойство.Вставить("type", "string");
	JsonrpcСвойство.Вставить("enum", ОдинЭлементВМассиве("2.0"));
	Свойства.Вставить("jsonrpc", JsonrpcСвойство);

	MethodСвойство = Новый Структура;
	MethodСвойство.Вставить("type", "string");
	MethodСвойство.Вставить("description", "Имя метода (см. описание выше)");
	Методы = http_СерверСлужебныйПовтИсп.МетодыJRPC();
	ЕnumМетодов = Новый Массив;
	Для Каждого Элемент Из Методы Цикл
		ЕnumМетодов.Добавить(Элемент.Ключ);
	КонецЦикла;
	Если ЕnumМетодов.Количество() > 0 Тогда
		MethodСвойство.Вставить("enum", ЕnumМетодов);
	КонецЕсли;
	Свойства.Вставить("method", MethodСвойство);

	ParamsСвойство = Новый Структура;
	ParamsСвойство.Вставить("description", "Параметры метода (массив или объект)");
	Свойства.Вставить("params", ParamsСвойство);

	IdСвойство = Новый Структура;
	IdСвойство.Вставить("description", "Идентификатор вызова. Если отсутствует - вызов трактуется как оповещение.");
	Свойства.Вставить("id", IdСвойство);

	Схема.Вставить("properties", Свойства);
	Возврат Схема;

КонецФункции

Функция СформироватьОтветыJRPC()

	Ответы = Новый Соответствие;

	Ответ200 = Новый Структура;
	Ответ200.Вставить("description", "Конверт ответа JSON-RPC 2.0 (или массив для пакетного запроса)");
	Контент = Новый Соответствие;
	JsonКонтент = Новый Структура;
	JsonКонтент.Вставить("schema", Новый Структура("type", "object"));
	Контент.Вставить("application/json", JsonКонтент);
	Ответ200.Вставить("content", Контент);
	Ответы.Вставить("200", Ответ200);

	Ответ500 = Новый Структура;
	Ответ500.Вставить("description", "Внутренняя ошибка обработки JSON-RPC");
	Ответы.Вставить("500", Ответ500);

	Возврат Ответы;

КонецФункции

#КонецОбласти

#Область Схемы

// Возвращает компоненты components.schemas. Сейчас оставлены пустыми -
// прикладные схемы войдут сюда в Фазе 6 (когда HTTPПодсистема сможет
// регистрировать общие модели).
Функция СформироватьСхемыJRPC()

	Возврат Новый Структура;

КонецФункции

// Преобразует http_СерверКлиентСервер-схему ({ИмяПоля: {Тип, Обязательный, ...}})
// в массив OpenAPI parameter objects с заданным in (path/query/header).
Процедура ДобавитьПараметрыИзСхемы(Параметры, Схема, Расположение)

	Если Схема = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Для Каждого Поле Из Схема Цикл

		Имя     = Поле.Ключ;
		Правила = Поле.Значение;

		Параметр = Новый Структура;
		Параметр.Вставить("name", Имя);
		Параметр.Вставить("in",   Расположение);

		Если ТипЗнч(Правила) = Тип("Строка") Тогда
			Параметр.Вставить("required", Расположение = "path");
			Параметр.Вставить("schema",   СхемаПоТипу(Правила));
		Иначе
			Параметр.Вставить("required",
				?(Правила.Свойство("Обязательный"), Правила.Обязательный, Расположение = "path"));
			Параметр.Вставить("schema", СхемаПоТипу(Правила.Тип));
		КонецЕсли;

		Параметры.Добавить(Параметр);

	КонецЦикла;

КонецПроцедуры

Функция СформироватьRequestBody(СхемаТела)

	RequestBody = Новый Структура;
	RequestBody.Вставить("required", Истина);

	СхемаОбъекта = Новый Структура;
	СхемаОбъекта.Вставить("type", "object");

	Свойства = Новый Структура;
	Обязательные = Новый Массив;
	Для Каждого Поле Из СхемаТела Цикл
		Имя     = Поле.Ключ;
		Правила = Поле.Значение;
		Свойства.Вставить(Имя, СхемаПоТипу(?(ТипЗнч(Правила) = Тип("Строка"), Правила, Правила.Тип)));
		Если ТипЗнч(Правила) = Тип("Структура") И Правила.Свойство("Обязательный") И Правила.Обязательный Тогда
			Обязательные.Добавить(Имя);
		КонецЕсли;
	КонецЦикла;
	СхемаОбъекта.Вставить("properties", Свойства);
	Если Обязательные.Количество() > 0 Тогда
		СхемаОбъекта.Вставить("required", Обязательные);
	КонецЕсли;

	JsonContent = Новый Структура;
	JsonContent.Вставить("schema", СхемаОбъекта);
	Контент = Новый Соответствие;
	Контент.Вставить("application/json", JsonContent);

	RequestBody.Вставить("content", Контент);
	Возврат RequestBody;

КонецФункции

Функция СхемаПоТипу(ИмяТипа)

	Схема = Новый Структура;
	Если ИмяТипа = "Число" Тогда
		Схема.Вставить("type", "number");
	ИначеЕсли ИмяТипа = "Булево" Тогда
		Схема.Вставить("type", "boolean");
	ИначеЕсли ИмяТипа = "Дата" Тогда
		Схема.Вставить("type",   "string");
		Схема.Вставить("format", "date-time");
	ИначеЕсли ИмяТипа = "Массив" Тогда
		Схема.Вставить("type",  "array");
		Схема.Вставить("items", Новый Структура);
	ИначеЕсли ИмяТипа = "Структура" Тогда
		Схема.Вставить("type", "object");
	Иначе
		Схема.Вставить("type", "string");
	КонецЕсли;
	Возврат Схема;

КонецФункции

#КонецОбласти

#Область Безопасность

Функция СформироватьSecurityИзМаршрута(НастройкиАутентификации)

	Если НастройкиАутентификации = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	ИмяСхемы = "";
	ТипЗначение = Неопределено;
	НастройкиАутентификации.Свойство("Тип", ТипЗначение);
	Если ТипЗначение = "Basic" Тогда
		ИмяСхемы = "Basic";
	ИначеЕсли ТипЗначение = "Bearer" Тогда
		ИмяСхемы = "Bearer";
	ИначеЕсли ТипЗначение = "APIKey" Тогда
		ИмяСхемы = "APIKey";
	Иначе
		Возврат Неопределено;
	КонецЕсли;

	Элемент = Новый Структура;
	Элемент.Вставить(ИмяСхемы, Новый Массив);
	Массив = Новый Массив;
	Массив.Добавить(Элемент);
	Возврат Массив;

КонецФункции

Функция СформироватьСтандартныеОтветы()

	Ответы = Новый Соответствие;
	Ответы.Вставить("200", Новый Структура("description", "Успешный ответ"));
	Ответы.Вставить("400", Новый Структура("description", "Ошибка валидации параметров"));
	Ответы.Вставить("401", Новый Структура("description", "Не аутентифицирован"));
	Ответы.Вставить("403", Новый Структура("description", "Доступ запрещён"));
	Ответы.Вставить("500", Новый Структура("description", "Внутренняя ошибка"));
	Возврат Ответы;

КонецФункции

