///////////////////////////////////////////////////////////////////////////////
// http_СерверКлиентСервер
//
// Утилиты и конструкторы, доступные на клиенте и сервере.
// Используется как для построения параметров маршрута прикладным кодом,
// так и внутри ядра http_HTTPКонвейер для разбора результатов.
///////////////////////////////////////////////////////////////////////////////

#Область ПрограммныйИнтерфейс

// Конструктор стандартной структуры параметров маршрута.
// Прикладной код может расширить полученную структуру перед вызовом
// http_HTTPКонвейер.ОбработатьЗапрос().
//
// Возвращаемое значение:
//  Структура - параметры маршрута со значениями по умолчанию:
//   * Аутентификация - Структура - { Тип: "None", Параметры: Структура } - не требуется.
//   * Авторизация    - Неопределено - не требуется.
//   * ФорматОтвета   - Строка - "JSON".
//   * СхемаПути      - Неопределено - без валидации.
//   * СхемаQuery     - Неопределено - без валидации.
//   * СхемаТела      - Неопределено - без валидации.
//   * CORS           - Неопределено - заголовки CORS не выставляются.
//   * Обработчик     - Строка - пусто, должен быть установлен прикладным кодом.
//   * Сервис         - Строка - имя для журнала, пусто = взять из URL.
//   * НастройкиЖурнала - Структура - { Включено, ЗаписыватьТелоЗапроса, ЗаписыватьТелоОтвета }.
//
Функция НовыйПараметрыМаршрута() Экспорт

	НастройкиАутентификации = Новый Структура;
	НастройкиАутентификации.Вставить("Тип",       "None");
	НастройкиАутентификации.Вставить("Параметры", Новый Структура);

	НастройкиЖурнала = Новый Структура;
	НастройкиЖурнала.Вставить("Включено",              Истина);
	НастройкиЖурнала.Вставить("ЗаписыватьТелоЗапроса", Истина);
	НастройкиЖурнала.Вставить("ЗаписыватьТелоОтвета",  Истина);

	ПараметрыМаршрута = Новый Структура;
	ПараметрыМаршрута.Вставить("Аутентификация",  НастройкиАутентификации);
	ПараметрыМаршрута.Вставить("Авторизация",     Неопределено);
	ПараметрыМаршрута.Вставить("ФорматОтвета",    "JSON");
	ПараметрыМаршрута.Вставить("СхемаПути",       Неопределено);
	ПараметрыМаршрута.Вставить("СхемаQuery",      Неопределено);
	ПараметрыМаршрута.Вставить("СхемаТела",       Неопределено);
	ПараметрыМаршрута.Вставить("CORS",            Неопределено);
	ПараметрыМаршрута.Вставить("Идемпотентность", Неопределено);
	ПараметрыМаршрута.Вставить("Обработчик",      "");
	ПараметрыМаршрута.Вставить("Сервис",          "");
	ПараметрыМаршрута.Вставить("НастройкиЖурнала", НастройкиЖурнала);

	Возврат ПараметрыМаршрута;

КонецФункции

// Конструктор описания параметра схемы валидации.
//
// Параметры:
//  Тип                - Строка    - имя типа: "Строка", "Число", "Булево", "Дата", "Массив", "Структура".
//  Обязательный       - Булево    - параметр обязателен.
//  ДопустимыеЗначения - Массив, Неопределено - перечень допустимых значений (enum).
//  МинЗначение        - Произвольный - нижняя граница (для чисел).
//  МаксЗначение       - Произвольный - верхняя граница.
//
// Возвращаемое значение:
//  Структура - правила валидации для одного параметра.
//
Функция ОписаниеПараметра(Тип, Обязательный = Ложь, ДопустимыеЗначения = Неопределено,
	МинЗначение = Неопределено, МаксЗначение = Неопределено) Экспорт

	Описание = Новый Структура;
	Описание.Вставить("Тип",                Тип);
	Описание.Вставить("Обязательный",       Обязательный);
	Описание.Вставить("ДопустимыеЗначения", ДопустимыеЗначения);
	Описание.Вставить("Мин",                МинЗначение);
	Описание.Вставить("Макс",               МаксЗначение);
	Возврат Описание;

КонецФункции

// Безопасное извлечение значения из Структуры или Соответствия.
// Возвращает Неопределено если поле отсутствует.
//
// Параметры:
//  Данные  - Структура, Соответствие
//  ИмяПоля - Строка
//
// Возвращаемое значение:
//  Произвольный, Неопределено
//
Функция ПолучитьПоле(Данные, ИмяПоля) Экспорт

	Если ТипЗнч(Данные) = Тип("Соответствие") Тогда
		Возврат Данные.Получить(ИмяПоля);
	ИначеЕсли ТипЗнч(Данные) = Тип("Структура") Тогда
		Значение = Неопределено;
		Данные.Свойство(ИмяПоля, Значение);
		Возврат Значение;
	КонецЕсли;
	Возврат Неопределено;

КонецФункции

#КонецОбласти
