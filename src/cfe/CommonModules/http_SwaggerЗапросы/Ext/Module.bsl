///////////////////////////////////////////////////////////////////////////////
// http_SwaggerЗапросы
//
// Обработчики HTTP-сервиса http_Swagger:
//   GET /swagger/swagger.json  -> сгенерированная OpenAPI 3.0 спецификация
//   GET /swagger/              -> Swagger UI (HTML, подгружает swagger-ui с CDN)
//   GET /swagger/index.html    -> то же
//
// Если потребуется offline UI - в Фазе 6+ добавим макеты с локальной копией
// swagger-ui-bundle.js / swagger-ui.css.
///////////////////////////////////////////////////////////////////////////////

#Область ПрограммныйИнтерфейс

// Обработчик /swagger/{File}.
//
// Параметры:
//  Запрос - HTTPСервисЗапрос
//
// Возвращаемое значение:
//  HTTPСервисОтвет
//
Функция ОбработатьЗапросФайла(Запрос) Экспорт

	ИмяФайла = Запрос.ПараметрыURL.Получить("File");
	Если ИмяФайла = Неопределено Тогда
		ИмяФайла = "";
	КонецЕсли;
	ИмяФайла = НРег(ИмяФайла);

	Если ИмяФайла = "swagger.json" Тогда
		Возврат ОтветJSON(Запрос);
	ИначеЕсли ИмяФайла = "" Или ИмяФайла = "index.html" Тогда
		Возврат ОтветHTML(Запрос);
	КонецЕсли;

	Ответ = Новый HTTPСервисОтвет(404);
	http_АдаптерЗапросОтветСлужебный.ОтветУстановитьТипСодержимого(Ответ, "application/json; charset=utf-8");
	http_АдаптерЗапросОтветСлужебный.ОтветУстановитьТело(Ответ,
		"{""code"":404,""error"":""Файл не найден"",""details"":""Доступны swagger.json и index.html""}");
	Возврат Ответ;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ОтветJSON(Запрос)

	БазовыйURL = ПолучитьБазовыйURLСервера(Запрос);
	// БазовыйURL заканчивается на "/swagger" - для spec нужен корень без /swagger
	БазаДляСервера = СтрЗаменить(БазовыйURL, "/swagger", "");

	Spec = http_SwaggerГенератор.СформироватьOpenAPI(БазаДляСервера);
	JSON = http_SwaggerГенератор.СпецификацияВJSON(Spec);

	Ответ = Новый HTTPСервисОтвет(200);
	http_АдаптерЗапросОтветСлужебный.ОтветУстановитьТипСодержимого(Ответ, "application/json; charset=utf-8");
	Ответ.УстановитьТелоИзСтроки(JSON, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	Возврат Ответ;

КонецФункции

Функция ОтветHTML(Запрос)

	БазовыйURL = ПолучитьБазовыйURLСервера(Запрос);
	HTML = ШаблонSwaggerUIHTML(БазовыйURL + "/swagger.json");

	Ответ = Новый HTTPСервисОтвет(200);
	http_АдаптерЗапросОтветСлужебный.ОтветУстановитьТипСодержимого(Ответ, "text/html; charset=utf-8");
	Ответ.УстановитьТелоИзСтроки(HTML, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	Возврат Ответ;

КонецФункции

// Возвращает базовый URL сервера с учётом порта из заголовка Host
// (платформа в БазовомURL порт не указывает).
Функция ПолучитьБазовыйURLСервера(Запрос)

	БазовыйURL = Запрос.БазовыйURL;
	Host = Запрос.Заголовки.Получить("Host");
	Если Не ПустаяСтрока(Host) И СтрНайти(Host, ":") > 0 Тогда
		МассивHost = СтрРазделить(Host, ":");
		Если МассивHost.Количество() > 1 Тогда
			БазовыйURL = СтрЗаменить(БазовыйURL, МассивHost[0], Host);
		КонецЕсли;
	КонецЕсли;
	Возврат БазовыйURL;

КонецФункции

// Минимальная HTML-страница Swagger UI с подгрузкой ресурсов с CDN.
// Если CDN недоступен (закрытый контур) - в Фазе 6+ добавить локальные макеты.
Функция ШаблонSwaggerUIHTML(URLСпецификации)

	Шаблон =
	"<!DOCTYPE html>
	|<html lang=""ru"">
	|<head>
	|	<meta charset=""UTF-8"">
	|	<title>http_HTTPСервер - API</title>
	|	<link rel=""stylesheet"" href=""https://unpkg.com/swagger-ui-dist@5/swagger-ui.css"">
	|	<style>body { margin: 0; padding: 0; }</style>
	|</head>
	|<body>
	|	<div id=""swagger-ui""></div>
	|	<script src=""https://unpkg.com/swagger-ui-dist@5/swagger-ui-bundle.js""></script>
	|	<script>
	|		window.ui = SwaggerUIBundle({
	|			url: '%1',
	|			dom_id: '#swagger-ui',
	|			deepLinking: true,
	|			tryItOutEnabled: true
	|		});
	|	</script>
	|</body>
	|</html>";

	Возврат СтрШаблон(Шаблон, URLСпецификации);

КонецФункции

#КонецОбласти
