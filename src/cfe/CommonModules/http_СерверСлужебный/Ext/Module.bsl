///////////////////////////////////////////////////////////////////////////////
// http_СерверСлужебный
//
// Сбор реестров из прикладных HTTPПодсистема-модулей и публичный API
// для исполнителей конвейера.
//
// Прикладной API:
//   ОбработатьЗапросПоМаршрутам(Запрос) - точка входа для REST HTTP-сервисов.
//   НовыйКонструкторМетодов()           - возвращает таблицу для регистрации JRPC-методов.
//   НовыйКонструкторМаршрутов()         - то же для REST-маршрутов.
//   ПолучитьМетодJRPC(ИмяМетода)        - доступ к одному методу из реестра.
///////////////////////////////////////////////////////////////////////////////

#Область ПрограммныйИнтерфейс

// Точка входа для REST-обработчиков прикладных HTTP-сервисов.
// Прикладной HTTP-сервис в своём обработчике URL-шаблона вызывает эту функцию;
// она ищет подходящий маршрут в реестре и запускает конвейер.
//
// Параметры:
//  Запрос - HTTPСервисЗапрос
//
// Возвращаемое значение:
//  HTTPСервисОтвет
//
Функция ОбработатьЗапросПоМаршрутам(Запрос) Экспорт

	Ответ = Новый HTTPСервисОтвет(200);

	ИмяСервиса = http_АдаптерЗапросОтветСлужебный.ЗапросИмяСервиса(Запрос);
	Метод      = http_АдаптерЗапросОтветСлужебный.ЗапросМетод(Запрос);

	Маршрут = НайтиМаршрут(Запрос, ИмяСервиса, Метод);
	Если Маршрут = Неопределено Тогда
		http_АдаптерЗапросОтветСлужебный.ОтветУстановитьКод(Ответ, 404);
		http_АдаптерЗапросОтветСлужебный.ОтветУстановитьТипСодержимого(Ответ, "application/json; charset=utf-8");
		http_АдаптерЗапросОтветСлужебный.ОтветУстановитьТело(Ответ,
			"{""code"":404,""error"":""Маршрут не зарегистрирован""}");
		Возврат Ответ;
	КонецЕсли;

	ПараметрыМаршрута = СформироватьПараметрыМаршрутаИзРеестра(Маршрут);
	http_HTTPКонвейер.ОбработатьЗапрос(Запрос, Ответ, ПараметрыМаршрута);
	Возврат Ответ;

КонецФункции

// Возвращает описание JRPC-метода из реестра по имени.
//
// Параметры:
//  ИмяМетода - Строка
//
// Возвращаемое значение:
//  Структура - см. http_СерверСлужебныйПовтИсп.МетодыJRPC().
//  Неопределено - если метод не зарегистрирован.
//
Функция ПолучитьМетодJRPC(ИмяМетода) Экспорт

	Реестр = http_СерверСлужебныйПовтИсп.МетодыJRPC();
	Возврат Реестр.Получить(ИмяМетода);

КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Проверяет что общий модуль с заданным именем - прикладная HTTPПодсистема.
// Признак: экспортная функция ЭтоHTTPПодсистема() возвращает Истина.
//
// Параметры:
//  ИмяМодуля - Строка
//
// Возвращаемое значение:
//  Булево
//
Функция ПроверитьМаркерHTTPПодсистемы(ИмяМодуля) Экспорт

	Попытка
		ОбщийМодуль = ОбщегоНазначения.ОбщийМодуль(ИмяМодуля);
		Возврат ОбщийМодуль.ЭтоHTTPПодсистема() = Истина;
	Исключение
		ОписаниеОшибкиИгнорируется = ОписаниеОшибки();
		Возврат Ложь;
	КонецПопытки;

КонецФункции

// Вызывает у прикладной подсистемы ПриЗаполненииМетодовJRPC и добавляет
// собранные методы в общий реестр.
//
// Параметры:
//  ИмяПодсистемы - Строка - имя общего модуля HTTPПодсистемы.
//  Реестр        - Соответствие - модифицируется.
//
Процедура ЗаполнитьМетодыJRPCПодсистемы(ИмяПодсистемы, Реестр) Экспорт

	Конструктор = НовыйКонструкторМетодов();

	Попытка
		ОбщийМодуль = ОбщегоНазначения.ОбщийМодуль(ИмяПодсистемы);
		ОбщийМодуль.ПриЗаполненииМетодовJRPC(Конструктор);
	Исключение
		ЗаписьЖурналаРегистрации(
			"http_СерверСлужебный: не удалось получить методы JRPC у " + ИмяПодсистемы,
			УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки());
		Возврат;
	КонецПопытки;

	Для Каждого СтрокаМетода Из Конструктор Цикл

		Если ПустаяСтрока(СтрокаМетода.Имя) Тогда
			Продолжить;
		КонецЕсли;

		Если Реестр.Получить(СтрокаМетода.Имя) <> Неопределено Тогда
			ЗаписьЖурналаРегистрации(
				"http_СерверСлужебный: JRPC-метод '" + СтрокаМетода.Имя + "' уже зарегистрирован; "
					+ ИмяПодсистемы + " перезаписывает",
				УровеньЖурналаРегистрации.Предупреждение);
		КонецЕсли;

		Описание = Новый Структура;
		Описание.Вставить("Имя",             СтрокаМетода.Имя);
		Описание.Вставить("Обработчик",      СтрокаМетода.Обработчик);
		Описание.Вставить("Описание",        СтрокаМетода.Описание);
		Описание.Вставить("Версия",          СтрокаМетода.Версия);
		Описание.Вставить("Устарел",         СтрокаМетода.Устарел);
		Описание.Вставить("ТипВызова",       ?(ПустаяСтрока(СтрокаМетода.ТипВызова), "Функция", СтрокаМетода.ТипВызова));
		Описание.Вставить("Аутентификация",  СтрокаМетода.Аутентификация);
		Описание.Вставить("Авторизация",     СтрокаМетода.Авторизация);
		Описание.Вставить("СхемаПараметров", СтрокаМетода.СхемаПараметров);

		Реестр.Вставить(СтрокаМетода.Имя, Описание);

	КонецЦикла;

КонецПроцедуры

// Вызывает у прикладной подсистемы ПриЗаполненииМаршрутовHTTP и добавляет
// собранные маршруты в общий реестр.
//
// Параметры:
//  ИмяПодсистемы - Строка
//  Реестр        - Соответствие - модифицируется.
//
Процедура ЗаполнитьМаршрутыHTTPПодсистемы(ИмяПодсистемы, Реестр) Экспорт

	Конструктор = НовыйКонструкторМаршрутов();

	Попытка
		ОбщийМодуль = ОбщегоНазначения.ОбщийМодуль(ИмяПодсистемы);
		ОбщийМодуль.ПриЗаполненииМаршрутовHTTP(Конструктор);
	Исключение
		// Метод не обязателен: подсистема может регистрировать только JRPC-методы
		ОписаниеОшибкиИгнорируется = ОписаниеОшибки();
		Возврат;
	КонецПопытки;

	Для Каждого СтрокаМаршрута Из Конструктор Цикл

		Если ПустаяСтрока(СтрокаМаршрута.Сервис) Или ПустаяСтрока(СтрокаМаршрута.ШаблонURL) Тогда
			Продолжить;
		КонецЕсли;

		Описание = Новый Структура;
		Описание.Вставить("Сервис",         СтрокаМаршрута.Сервис);
		Описание.Вставить("ШаблонURL",      СтрокаМаршрута.ШаблонURL);
		Описание.Вставить("HTTPМетод",      СтрокаМаршрута.HTTPМетод);
		Описание.Вставить("Обработчик",     СтрокаМаршрута.Обработчик);
		Описание.Вставить("Описание",       СтрокаМаршрута.Описание);
		Описание.Вставить("Аутентификация", СтрокаМаршрута.Аутентификация);
		Описание.Вставить("Авторизация",    СтрокаМаршрута.Авторизация);
		Описание.Вставить("СхемаПути",      СтрокаМаршрута.СхемаПути);
		Описание.Вставить("СхемаQuery",     СтрокаМаршрута.СхемаQuery);
		Описание.Вставить("СхемаТела",      СтрокаМаршрута.СхемаТела);
		Описание.Вставить("CORS",           СтрокаМаршрута.CORS);

		Ключ = СтрокаМаршрута.Сервис + " " + СтрокаМаршрута.HTTPМетод + " " + СтрокаМаршрута.ШаблонURL;
		Реестр.Вставить(Ключ, Описание);

	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Конструктор таблицы для регистрации JRPC-методов.
// Прикладной код в ПриЗаполненииМетодовJRPC(Методы) делает:
//   Метод = Методы.Добавить();
//   Метод.Имя         = "users.find";
//   Метод.Обработчик  = "МоиJRPC.Найти";
//   Метод.ТипВызова   = "Функция";
//   ...
//
// Возвращаемое значение:
//  ТаблицаЗначений
//
Функция НовыйКонструкторМетодов() Экспорт

	Таблица = Новый ТаблицаЗначений;
	Таблица.Колонки.Добавить("Имя",             Новый ОписаниеТипов("Строка"));
	Таблица.Колонки.Добавить("Обработчик",      Новый ОписаниеТипов("Строка"));
	Таблица.Колонки.Добавить("Описание",        Новый ОписаниеТипов("Строка"));
	Таблица.Колонки.Добавить("Версия",          Новый ОписаниеТипов("Строка"));
	Таблица.Колонки.Добавить("Устарел",         Новый ОписаниеТипов("Булево"));
	Таблица.Колонки.Добавить("ТипВызова",       Новый ОписаниеТипов("Строка"));
	Таблица.Колонки.Добавить("Аутентификация");
	Таблица.Колонки.Добавить("Авторизация");
	Таблица.Колонки.Добавить("СхемаПараметров");
	Возврат Таблица;

КонецФункции

// Конструктор таблицы для регистрации REST-маршрутов.
//
// Возвращаемое значение:
//  ТаблицаЗначений
//
Функция НовыйКонструкторМаршрутов() Экспорт

	Таблица = Новый ТаблицаЗначений;
	Таблица.Колонки.Добавить("Сервис",      Новый ОписаниеТипов("Строка"));
	Таблица.Колонки.Добавить("ШаблонURL",   Новый ОписаниеТипов("Строка"));
	Таблица.Колонки.Добавить("HTTPМетод",   Новый ОписаниеТипов("Строка"));
	Таблица.Колонки.Добавить("Обработчик",  Новый ОписаниеТипов("Строка"));
	Таблица.Колонки.Добавить("Описание",    Новый ОписаниеТипов("Строка"));
	Таблица.Колонки.Добавить("Аутентификация");
	Таблица.Колонки.Добавить("Авторизация");
	Таблица.Колонки.Добавить("СхемаПути");
	Таблица.Колонки.Добавить("СхемаQuery");
	Таблица.Колонки.Добавить("СхемаТела");
	Таблица.Колонки.Добавить("CORS");
	Возврат Таблица;

КонецФункции

// Простое сопоставление маршрута по (Сервис, Метод, точное вхождение шаблона).
// Полноценный matching по параметрам пути - в Фазе 5.
Функция НайтиМаршрут(Запрос, ИмяСервиса, Метод)

	Реестр = http_СерверСлужебныйПовтИсп.МаршрутыHTTP();
	Адрес  = http_АдаптерЗапросОтветСлужебный.ЗапросАдрес(Запрос);

	Для Каждого ЭлементРеестра Из Реестр Цикл
		Маршрут = ЭлементРеестра.Значение;
		Если Маршрут.Сервис    <> ИмяСервиса Тогда
			Продолжить;
		КонецЕсли;
		Если Маршрут.HTTPМетод <> Метод Тогда
			Продолжить;
		КонецЕсли;
		Если СтрНайти(Адрес, Маршрут.ШаблонURL) = 0 Тогда
			Продолжить;
		КонецЕсли;
		Возврат Маршрут;
	КонецЦикла;

	Возврат Неопределено;

КонецФункции

Функция СформироватьПараметрыМаршрутаИзРеестра(Маршрут)

	ПараметрыМаршрута = http_СерверКлиентСервер.НовыйПараметрыМаршрута();

	ПараметрыМаршрута.Сервис     = Маршрут.Сервис;
	ПараметрыМаршрута.Обработчик = Маршрут.Обработчик;

	Если Маршрут.Аутентификация <> Неопределено Тогда
		ПараметрыМаршрута.Аутентификация = Маршрут.Аутентификация;
	КонецЕсли;
	Если Маршрут.Авторизация <> Неопределено Тогда
		ПараметрыМаршрута.Авторизация = Маршрут.Авторизация;
	КонецЕсли;

	ПараметрыМаршрута.СхемаПути  = Маршрут.СхемаПути;
	ПараметрыМаршрута.СхемаQuery = Маршрут.СхемаQuery;
	ПараметрыМаршрута.СхемаТела  = Маршрут.СхемаТела;
	ПараметрыМаршрута.CORS       = Маршрут.CORS;

	Возврат ПараметрыМаршрута;

КонецФункции

#КонецОбласти
