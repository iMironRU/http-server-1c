///////////////////////////////////////////////////////////////////////////////
// http_ДемоJRPCHTTPПодсистема
//
// Демо-подсистема: показывает как прикладной модуль регистрирует JRPC-методы.
// Существует чтобы:
//   1. Smoke-тест JRPC-конвейера и реестра автообнаружения.
//   2. Пример для прикладных разработчиков (копипаст-шаблон).
//
// Контракт автообнаружения:
//   - Имя модуля должно заканчиваться на "HTTPПодсистема".
//   - Должна быть экспортная функция ЭтоHTTPПодсистема() Экспорт Возврат Истина;
//   - Должна быть экспортная процедура ПриЗаполненииМетодовJRPC(Методы) Экспорт
//     (для регистрации JRPC-методов; необязательно если только REST).
//   - Опционально: ПриЗаполненииМаршрутовHTTP(Маршруты) Экспорт для REST.
//
// Удалить этот модуль при появлении в проекте прикладных HTTPПодсистема-модулей.
///////////////////////////////////////////////////////////////////////////////

#Область ПрограммныйИнтерфейс

// Маркер: подтверждает что модуль предназначен для http_HTTPСервер.
// Без этой функции наш фреймворк проигнорирует модуль.
//
//@skip-check module-empty-function
Функция ЭтоHTTPПодсистема() Экспорт

	Возврат Истина;

КонецФункции

// Регистрация JRPC-методов этой подсистемы.
// Вызывается фреймворком при первом обращении к реестру (кэшируется на сеанс).
//
// Параметры:
//  Методы - ТаблицаЗначений - см. http_СерверСлужебный.НовыйКонструкторМетодов().
//
Процедура ПриЗаполненииМетодовJRPC(Методы) Экспорт

	Метод = Методы.Добавить();
	Метод.Имя        = "demo.echo";
	Метод.Обработчик = "http_ДемоJRPCHTTPПодсистема.Echo";
	Метод.Описание   = "Возвращает входные параметры без изменений (smoke-test)";
	Метод.Версия     = "1.0";
	Метод.ТипВызова  = "Функция";

	Метод = Методы.Добавить();
	Метод.Имя        = "demo.sum";
	Метод.Обработчик = "http_ДемоJRPCHTTPПодсистема.Sum";
	Метод.Описание   = "Сумма двух чисел";
	Метод.Версия     = "1.0";
	Метод.ТипВызова  = "Функция";

КонецПроцедуры

// Обработчик метода demo.echo. Возвращает params неизменными.
//
// Параметры:
//  Параметры - Произвольный - params JSON-RPC-вызова (массив или объект).
//
Функция Echo(Параметры) Экспорт

	Возврат Параметры;

КонецФункции

// Обработчик метода demo.sum. Складывает params[0] + params[1].
//
// Параметры:
//  Параметры - Массив - [a, b].
//
Функция Sum(Параметры) Экспорт

	Если ТипЗнч(Параметры) <> Тип("Массив") Или Параметры.Количество() < 2 Тогда
		ВызватьИсключение "Требуется массив params из двух чисел";
	КонецЕсли;
	Возврат Параметры[0] + Параметры[1];

КонецФункции

#КонецОбласти
