///////////////////////////////////////////////////////////////////////////////
// http_РегламентныеЗадания
//
// Обработчики регламентных заданий:
//   * РазблокироватьКонфликты - помечает зависшие запросы как истёкшие.
//   * СократитьЖурналы        - удаляет устаревшие записи журналов.
//
// Запуск контролируется константой http_ИспользоватьРегламентныеЗадания.
// Если константа = Ложь, обработчики сразу выходят без работы.
///////////////////////////////////////////////////////////////////////////////

#Область ПрограммныйИнтерфейс

// Помечает зависшие запросы (КодСостояния = 0) старше таймаута как 408 Request
// Timeout. После этого их Idempotency-Key освобождается для повторных запросов.
//
// Таймаут считается от ВремениНачала записи (универсальное время в мс).
// По умолчанию - 5 минут.
//
Процедура РазблокироватьКонфликты() Экспорт

	УстановитьПривилегированныйРежим(Истина);

	Если Не Константы.http_ИспользоватьРегламентныеЗадания.Получить() Тогда
		Возврат;
	КонецЕсли;

	ТаймаутМс = ТаймаутРазблокировкиМс();
	ГраницаВремени = ТекущаяУниверсальнаяДатаВМиллисекундах() - ТаймаутМс;

	Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	Журнал.Идентификатор КАК Идентификатор
		|ИЗ
		|	РегистрСведений.http_ЖурналВходящихЗапросов КАК Журнал
		|ГДЕ
		|	Журнал.КодСостояния = 0
		|	И Журнал.ВремяНачала < &ГраницаВремени");
	Запрос.УстановитьПараметр("ГраницаВремени", ГраницаВремени);

	Выборка = Запрос.Выполнить().Выбрать();

	Пока Выборка.Следующий() Цикл
		ОтметитьЗаписьКакИстёкшую(Выборка.Идентификатор);
	КонецЦикла;

КонецПроцедуры

// Удаляет записи журнала старше N дней (N задаётся в константе или дефолт 30).
Процедура СократитьЖурналы() Экспорт

	УстановитьПривилегированныйРежим(Истина);

	Если Не Константы.http_ИспользоватьРегламентныеЗадания.Получить() Тогда
		Возврат;
	КонецЕсли;

	ДнейХраненияПоУмолчанию = 30;
	ДатаГраница = НачалоДня(ТекущаяДатаСеанса()) - ДнейХраненияПоУмолчанию * 86400;

	Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Журнал.Идентификатор КАК Идентификатор
		|ИЗ
		|	РегистрСведений.http_ЖурналВходящихЗапросов КАК Журнал
		|ГДЕ
		|	Журнал.ДатаЗапроса < &ДатаГраница");
	Запрос.УстановитьПараметр("ДатаГраница", ДатаГраница);

	Выборка = Запрос.Выполнить().Выбрать();

	Пока Выборка.Следующий() Цикл
		УдалитьЗаписьЖурнала(Выборка.Идентификатор);
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТаймаутРазблокировкиМс()

	// 5 минут. Прикладной код может переопределить через свой обработчик регламентного задания
	Возврат 5 * 60 * 1000;

КонецФункции

Процедура ОтметитьЗаписьКакИстёкшую(Идентификатор)

	НаборЗаписей = РегистрыСведений.http_ЖурналВходящихЗапросов.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Идентификатор.Установить(Идентификатор);
	НаборЗаписей.Прочитать();
	Для Каждого Запись Из НаборЗаписей Цикл
		Запись.КодСостояния = 408;
		Запись.Ответ        = "{""code"":408,""error"":""Request timeout (released by scheduled job)""}";
	КонецЦикла;
	НаборЗаписей.Записать();

КонецПроцедуры

Процедура УдалитьЗаписьЖурнала(Идентификатор)

	НаборЗаписей = РегистрыСведений.http_ЖурналВходящихЗапросов.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Идентификатор.Установить(Идентификатор);
	НаборЗаписей.Записать(); // пустой набор - удаляет запись

КонецПроцедуры

#КонецОбласти
