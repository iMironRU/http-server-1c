///////////////////////////////////////////////////////////////////////////////
// http_СерверСлужебныйПовтИсп
//
// Кэш реестров на время сеанса. Реестры собираются единожды при первом
// обращении и хранятся в кэше повторного использования (ReturnValuesReuse=DuringSession).
//
// При изменении состава прикладных HTTPПодсистема-модулей или их содержимого
// нужно перезапустить сеанс.
///////////////////////////////////////////////////////////////////////////////

#Область СлужебныйПрограммныйИнтерфейс

// Возвращает список имён общих модулей, реализующих HTTPПодсистема.
// Соглашение:
//   1. Имя модуля заканчивается на "HTTPПодсистема".
//   2. В модуле есть экспортная функция ЭтоHTTPПодсистема() Экспорт,
//      возвращающая Истина.
//
// Возвращаемое значение:
//  ФиксированныйМассив из Строка
//
Функция ПодсистемыHTTP() Экспорт

	Подсистемы = Новый Массив;
	СуффиксИмени = "HTTPПодсистема";

	Для Каждого ОбщийМодульМД Из Метаданные.ОбщиеМодули Цикл

		ИмяМодуля = ОбщийМодульМД.Имя;
		Если Не СтрЗаканчиваетсяНа(ИмяМодуля, СуффиксИмени) Тогда
			Продолжить;
		КонецЕсли;

		Если Не http_СерверСлужебный.ПроверитьМаркерHTTPПодсистемы(ИмяМодуля) Тогда
			Продолжить;
		КонецЕсли;

		Подсистемы.Добавить(ИмяМодуля);

	КонецЦикла;

	Возврат Новый ФиксированныйМассив(Подсистемы);

КонецФункции

// Реестр JRPC-методов, собранный из всех HTTPПодсистем.
//
// Ключ - имя метода (Строка, "users.find" - точечная нотация по соглашению).
// Значение - Структура с полями:
//   * Имя             - Строка
//   * Обработчик      - Строка - "ИмяМодуля.ИмяФункции"
//   * Описание        - Строка - человекочитаемое описание (для swagger)
//   * Версия          - Строка
//   * Устарел         - Булево - deprecated
//   * ТипВызова       - Строка - "Функция" / "Процедура" / "Оповещение"
//   * Аутентификация  - Структура / Неопределено
//   * Авторизация     - Структура / Неопределено
//   * СхемаПараметров - Структура / Неопределено
//
// Возвращаемое значение:
//  ФиксированноеСоответствие
//
Функция МетодыJRPC() Экспорт

	Реестр = Новый Соответствие;
	Для Каждого ИмяПодсистемы Из ПодсистемыHTTP() Цикл
		http_СерверСлужебный.ЗаполнитьМетодыJRPCПодсистемы(ИмяПодсистемы, Реестр);
	КонецЦикла;
	Возврат Новый ФиксированноеСоответствие(Реестр);

КонецФункции

// Реестр REST-маршрутов.
//
// Ключ - "ИмяСервиса HTTPМетод ШаблонURL".
// Значение - Структура с полями:
//   * Сервис          - Строка
//   * ШаблонURL       - Строка
//   * HTTPМетод       - Строка
//   * Обработчик      - Строка - "ИмяМодуля.ИмяФункции"
//   * Описание        - Строка
//   * Аутентификация  - Структура / Неопределено
//   * Авторизация     - Структура / Неопределено
//   * СхемаПути       - Структура / Неопределено
//   * СхемаQuery      - Структура / Неопределено
//   * СхемаТела       - Структура / Неопределено
//   * CORS            - Произвольный / Неопределено
//
// Возвращаемое значение:
//  ФиксированноеСоответствие
//
Функция МаршрутыHTTP() Экспорт

	Реестр = Новый Соответствие;
	Для Каждого ИмяПодсистемы Из ПодсистемыHTTP() Цикл
		http_СерверСлужебный.ЗаполнитьМаршрутыHTTPПодсистемы(ИмяПодсистемы, Реестр);
	КонецЦикла;
	Возврат Новый ФиксированноеСоответствие(Реестр);

КонецФункции

// Возвращает кэшированные настройки HTTP-сервиса по его имени.
// Источник правды - Справочник.http_HTTPСервисы (см. модуль менеджера).
// Кэш живёт до конца сеанса; после изменения справочника нужно перезапустить
// сеанс или вызывать менеджер.НастройкиСервиса() напрямую.
//
// Параметры:
//  ИмяСервиса - Строка
//
// Возвращаемое значение:
//  Структура - см. Справочники.http_HTTPСервисы.НастройкиПоУмолчанию().
//
Функция НастройкиHTTPСервиса(ИмяСервиса) Экспорт

	Возврат Справочники.http_HTTPСервисы.НастройкиСервиса(ИмяСервиса);

КонецФункции

#КонецОбласти
