///////////////////////////////////////////////////////////////////////////////
// http_АдаптерЗапросОтветСлужебный
//
// Адаптер для унификации работы с двумя API HTTP, существующими в платформе 1С:
//   - HTTPСервисЗапрос / HTTPСервисОтвет - из обработчиков HTTPService
//   - HTTPЗапрос       / HTTPОтвет       - из обработчиков подсистемы "Веб-сервер"
//
// Все обращения к свойствам запроса и установка свойств ответа в http_HTTPКонвейер
// идут только через этот модуль.
///////////////////////////////////////////////////////////////////////////////

#Область СлужебныйПрограммныйИнтерфейс

#Область ОтветАдаптер

// Устанавливает код состояния ответа.
//
// Параметры:
//  Ответ - HTTPСервисОтвет, HTTPОтвет - объект ответа платформы.
//  Код   - Число - HTTP-статус.
//
Процедура ОтветУстановитьКод(Ответ, Код) Экспорт

	Если ТипЗнч(Ответ) = Тип("HTTPСервисОтвет") Тогда
		Ответ.КодСостояния = Код;
	Иначе
		Ответ.УстановитьКодСостояния(Код);
	КонецЕсли;

КонецПроцедуры

// Возвращает текущий код состояния ответа.
//
// Параметры:
//  Ответ - HTTPСервисОтвет, HTTPОтвет - объект ответа платформы.
//
// Возвращаемое значение:
//  Число - HTTP-статус.
//
Функция ОтветПолучитьКод(Ответ) Экспорт

	Если ТипЗнч(Ответ) = Тип("HTTPСервисОтвет") Тогда
		Возврат Ответ.КодСостояния;
	Иначе
		Возврат Ответ.ПолучитьКодСостояния();
	КонецЕсли;

КонецФункции

// Устанавливает заголовок ответа.
//
// Параметры:
//  Ответ        - HTTPСервисОтвет, HTTPОтвет
//  ИмяЗаголовка - Строка
//  Значение     - Строка
//
Процедура ОтветУстановитьЗаголовок(Ответ, ИмяЗаголовка, Значение) Экспорт

	Если ТипЗнч(Ответ) = Тип("HTTPСервисОтвет") Тогда
		Ответ.Заголовки.Вставить(ИмяЗаголовка, Значение);
	Иначе
		Ответ.УстановитьЗаголовок(ИмяЗаголовка, Значение);
	КонецЕсли;

КонецПроцедуры

// Устанавливает Content-Type ответа.
//
// Параметры:
//  Ответ          - HTTPСервисОтвет, HTTPОтвет
//  ТипСодержимого - Строка - значение заголовка Content-Type.
//
Процедура ОтветУстановитьТипСодержимого(Ответ, ТипСодержимого) Экспорт

	ОтветУстановитьЗаголовок(Ответ, "Content-Type", ТипСодержимого);

КонецПроцедуры

// Устанавливает тело ответа из строки.
//
// Параметры:
//  Ответ  - HTTPСервисОтвет, HTTPОтвет
//  Строка - Строка - содержимое тела.
//
Процедура ОтветУстановитьТело(Ответ, Строка) Экспорт

	Ответ.УстановитьТелоИзСтроки(Строка);

КонецПроцедуры

// Возвращает тело ответа как строку. Пустая строка если недоступно.
//
// Параметры:
//  Ответ - HTTPСервисОтвет, HTTPОтвет
//
// Возвращаемое значение:
//  Строка
//
Функция ОтветПолучитьТело(Ответ) Экспорт

	Попытка
		Возврат Ответ.ПолучитьТелоКакСтроку();
	Исключение
		Возврат "";
	КонецПопытки;

КонецФункции

#КонецОбласти

#Область ЗапросАдаптер

// Извлекает имя HTTP-сервиса из URL запроса.
// Для HTTPСервисЗапрос - последний сегмент БазовогоURL.
// Для HTTPЗапрос       - первый сегмент пути АдресРесурса.
// Если извлечь не удалось - возвращает пустую строку.
//
// Параметры:
//  Запрос - HTTPСервисЗапрос, HTTPЗапрос
//
// Возвращаемое значение:
//  Строка
//
Функция ЗапросИмяСервиса(Запрос) Экспорт

	Попытка
		Если ТипЗнч(Запрос) = Тип("HTTPСервисЗапрос") Тогда
			Части = СтрРазделить(Запрос.БазовыйURL, "/", Ложь);
			Если Части.Количество() > 0 Тогда
				Возврат Части[Части.Количество() - 1];
			КонецЕсли;
		Иначе
			Части = СтрРазделить(Запрос.АдресРесурса, "/", Ложь);
			Если Части.Количество() > 0 Тогда
				Возврат Части[0];
			КонецЕсли;
		КонецЕсли;
	Исключение
		// Игнорируем - вернём пустую строку
		ОписаниеОшибкиИгнорируется = ОписаниеОшибки();
	КонецПопытки;

	Возврат "";

КонецФункции

// Возвращает HTTP-метод запроса (GET, POST и т.д.).
//
// Параметры:
//  Запрос - HTTPСервисЗапрос, HTTPЗапрос
//
// Возвращаемое значение:
//  Строка
//
Функция ЗапросМетод(Запрос) Экспорт

	Если ТипЗнч(Запрос) = Тип("HTTPСервисЗапрос") Тогда
		Возврат Запрос.HTTPМетод;
	Иначе
		Возврат Запрос.Метод;
	КонецЕсли;

КонецФункции

// Возвращает полный адрес запроса.
//
// Параметры:
//  Запрос - HTTPСервисЗапрос, HTTPЗапрос
//
// Возвращаемое значение:
//  Строка
//
Функция ЗапросАдрес(Запрос) Экспорт

	Если ТипЗнч(Запрос) = Тип("HTTPСервисЗапрос") Тогда
		Возврат Запрос.БазовыйURL + Запрос.ОтносительныйURL;
	Иначе
		Возврат Запрос.АдресРесурса;
	КонецЕсли;

КонецФункции

// Возвращает значение заголовка запроса или Неопределено если отсутствует.
//
// Параметры:
//  Запрос       - HTTPСервисЗапрос, HTTPЗапрос
//  ИмяЗаголовка - Строка
//
// Возвращаемое значение:
//  Строка, Неопределено
//
Функция ЗапросЗаголовок(Запрос, ИмяЗаголовка) Экспорт

	Возврат Запрос.Заголовки.Получить(ИмяЗаголовка);

КонецФункции

// Возвращает Истина если запрос содержит непустое тело.
//
// Параметры:
//  Запрос - HTTPСервисЗапрос, HTTPЗапрос
//
// Возвращаемое значение:
//  Булево
//
Функция ЗапросЕстьТело(Запрос) Экспорт

	Если ТипЗнч(Запрос) = Тип("HTTPСервисЗапрос") Тогда
		Попытка
			Возврат СтрДлина(Запрос.ПолучитьТелоКакСтроку()) > 0;
		Исключение
			Возврат Ложь;
		КонецПопытки;
	Иначе
		Возврат Запрос.ЕстьТело();
	КонецЕсли;

КонецФункции

// Возвращает тело запроса как строку.
//
// Параметры:
//  Запрос - HTTPСервисЗапрос, HTTPЗапрос
//
// Возвращаемое значение:
//  Строка
//
Функция ЗапросТелоКакСтрока(Запрос) Экспорт

	Возврат Запрос.ПолучитьТелоКакСтроку();

КонецФункции

// Возвращает параметры пути URL как Соответствие.
//
// Параметры:
//  Запрос - HTTPСервисЗапрос, HTTPЗапрос
//
// Возвращаемое значение:
//  Соответствие
//
Функция ЗапросПараметрыПути(Запрос) Экспорт

	Возврат КоллекциюВСоответствие(Запрос.ПараметрыURL);

КонецФункции

// Возвращает параметры строки запроса (?key=value) как Соответствие.
//
// Параметры:
//  Запрос - HTTPСервисЗапрос, HTTPЗапрос
//
// Возвращаемое значение:
//  Соответствие
//
Функция ЗапросПараметрыQuery(Запрос) Экспорт

	Возврат КоллекциюВСоответствие(Запрос.ПараметрыЗапроса);

КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Преобразует коллекцию КлючЗначение в Соответствие.
//
// Параметры:
//  Коллекция - любая коллекция элементов КлючЗначение
//
// Возвращаемое значение:
//  Соответствие
//
Функция КоллекциюВСоответствие(Коллекция)

	Результат = Новый Соответствие;
	Если Коллекция = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	Для Каждого КлючЗначение Из Коллекция Цикл
		Результат.Вставить(КлючЗначение.Ключ, КлючЗначение.Значение);
	КонецЦикла;
	Возврат Результат;

КонецФункции

#КонецОбласти
