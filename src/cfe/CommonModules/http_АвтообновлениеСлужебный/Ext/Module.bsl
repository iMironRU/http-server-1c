///////////////////////////////////////////////////////////////////////////////
// http_АвтообновлениеСлужебный
//
// Проверка и установка обновлений расширения через GitHub Releases API.
//
// Источник URL репозитория - константа http_URLGitHubРепозиторий
// (формат "owner/repo" или полный URL https://github.com/owner/repo).
//
// Логика:
//   1. ПолучитьИнформациюОПоследнемРелизе() - GET api.github.com/.../releases/latest
//   2. Сравнение версии релиза с Метаданные.Версия
//   3. УстановитьОбновлениеИзРелиза(URL) - GET browser_download_url, ДД cfe
//   4. Запись через РасширенияКонфигурации.Получить + ПолучитьИзДанныхКонфигурации
//
// ВАЖНО: после Записать() новая версия применится только в новых сеансах.
///////////////////////////////////////////////////////////////////////////////

#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Возвращаемое значение:
//  Структура:
//   * Успех         - Булево
//   * Сообщение     - Строка - если Не Успех или дополнительные предупреждения
//   * ТекущаяВерсия - Строка - Метаданные.Версия
//   * НоваяВерсия   - Строка - tag_name релиза без префикса 'v'
//   * URLФайла      - Строка - browser_download_url первого *.cfe в assets
//   * ИмяФайла      - Строка
//   * РазмерБайт    - Число
//   * ОписаниеРелиза - Строка
//   * URLРелиза     - Строка
//   * ЕстьОбновление - Булево
//
Функция ПолучитьИнформациюОПоследнемРелизе() Экспорт

	Результат = НовыйРезультатПроверки();

	URLРепо = СокрЛП(Константы.http_URLGitHubРепозиторий.Получить());
	Если ПустаяСтрока(URLРепо) Тогда
		Результат.Сообщение = "Не задана константа http_URLGitHubРепозиторий. Формат 'owner/repo'.";
		Возврат Результат;
	КонецЕсли;

	URLРепо = НормализоватьРепо(URLРепо);
	Если ПустаяСтрока(URLРепо) Тогда
		Результат.Сообщение = "Некорректный URL репозитория. Используйте 'owner/repo'.";
		Возврат Результат;
	КонецЕсли;

	АдресAPI = "/repos/" + URLРепо + "/releases/latest";

	Попытка
		ОтветJSON = ВыполнитьGETЗапросGitHub(АдресAPI);
	Исключение
		Результат.Сообщение = "Ошибка обращения к GitHub API: " + ОписаниеОшибки();
		Возврат Результат;
	КонецПопытки;

	Если ТипЗнч(ОтветJSON) <> Тип("Структура") Тогда
		Результат.Сообщение = "Неожиданный формат ответа от GitHub API";
		Возврат Результат;
	КонецЕсли;

	ТегВерсии = "";
	ОтветJSON.Свойство("tag_name", ТегВерсии);
	НоваяВерсия = НормализоватьВерсию(ТегВерсии);

	URLРелиза = "";
	ОтветJSON.Свойство("html_url", URLРелиза);

	ОписаниеРелиза = "";
	ОтветJSON.Свойство("body", ОписаниеРелиза);

	URLФайла   = "";
	ИмяФайла   = "";
	РазмерБайт = 0;
	Ассеты = Неопределено;
	Если ОтветJSON.Свойство("assets", Ассеты) И ТипЗнч(Ассеты) = Тип("Массив") Тогда
		Для Каждого Ассет Из Ассеты Цикл
			ИмяАссета = "";
			Ассет.Свойство("name", ИмяАссета);
			Если СтрЗаканчиваетсяНа(НРег(ИмяАссета), ".cfe") Тогда
				Ассет.Свойство("browser_download_url", URLФайла);
				ИмяФайла = ИмяАссета;
				Ассет.Свойство("size", РазмерБайт);
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	ТекущаяВерсия = НормализоватьВерсию(Строка(Метаданные.Версия));

	Результат.Успех          = Истина;
	Результат.ТекущаяВерсия  = ТекущаяВерсия;
	Результат.НоваяВерсия    = НоваяВерсия;
	Результат.URLФайла       = URLФайла;
	Результат.ИмяФайла       = ИмяФайла;
	Результат.РазмерБайт     = РазмерБайт;
	Результат.ОписаниеРелиза = ОписаниеРелиза;
	Результат.URLРелиза      = URLРелиза;
	Результат.ЕстьОбновление = СравнитьВерсии(НоваяВерсия, ТекущаяВерсия) > 0;

	Если ПустаяСтрока(URLФайла) Тогда
		Результат.Сообщение = "В релизе " + НоваяВерсия + " нет .cfe-файла в assets";
	КонецЕсли;

	Возврат Результат;

КонецФункции

// Скачивает cfe и применяет как новую версию ТЕКУЩЕГО расширения.
//
// Параметры:
//  URLФайла - Строка - browser_download_url из ПолучитьИнформациюОПоследнемРелизе.
//
// Возвращаемое значение:
//  Структура - {Успех: Булево, Сообщение: Строка}
//
Функция УстановитьОбновлениеИзРелиза(URLФайла) Экспорт

	Результат = Новый Структура("Успех, Сообщение", Ложь, "");

	Если ПустаяСтрока(URLФайла) Тогда
		Результат.Сообщение = "Не передан URL файла обновления";
		Возврат Результат;
	КонецЕсли;

	Попытка
		ДанныеCFE = СкачатьФайлПоURL(URLФайла);
	Исключение
		Результат.Сообщение = "Ошибка скачивания cfe: " + ОписаниеОшибки();
		Возврат Результат;
	КонецПопытки;

	Если ДанныеCFE = Неопределено Или ДанныеCFE.Размер() = 0 Тогда
		Результат.Сообщение = "Скачан пустой файл";
		Возврат Результат;
	КонецЕсли;

	Попытка
		ПрименитьCFEКТекущемуРасширению(ДанныеCFE);
	Исключение
		Результат.Сообщение = "Ошибка применения cfe: " + ОписаниеОшибки();
		Возврат Результат;
	КонецПопытки;

	Результат.Успех = Истина;
	Результат.Сообщение = "Обновление установлено (" + Строка(ДанныеCFE.Размер())
		+ " байт). Завершите работу и перезайдите чтобы новая версия применилась.";
	Возврат Результат;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция НовыйРезультатПроверки()

	Р = Новый Структура;
	Р.Вставить("Успех",          Ложь);
	Р.Вставить("Сообщение",      "");
	Р.Вставить("ТекущаяВерсия",  "");
	Р.Вставить("НоваяВерсия",    "");
	Р.Вставить("URLФайла",       "");
	Р.Вставить("ИмяФайла",       "");
	Р.Вставить("РазмерБайт",     0);
	Р.Вставить("ОписаниеРелиза", "");
	Р.Вставить("URLРелиза",      "");
	Р.Вставить("ЕстьОбновление", Ложь);
	Возврат Р;

КонецФункции

Функция НормализоватьРепо(URLРепо)

	Значение = СокрЛП(URLРепо);
	Значение = СтрЗаменить(Значение, "https://github.com/", "");
	Значение = СтрЗаменить(Значение, "http://github.com/",  "");
	Значение = СтрЗаменить(Значение, "github.com/",          "");
	Значение = СтрЗаменить(Значение, ".git",                 "");
	Если СтрНачинаетсяС(Значение, "/") Тогда
		Значение = Сред(Значение, 2);
	КонецЕсли;
	Если СтрЗаканчиваетсяНа(Значение, "/") Тогда
		Значение = Лев(Значение, СтрДлина(Значение) - 1);
	КонецЕсли;
	Если СтрРазделить(Значение, "/").Количество() <> 2 Тогда
		Возврат "";
	КонецЕсли;
	Возврат Значение;

КонецФункции

Функция НормализоватьВерсию(Версия)

	Значение = СокрЛП(Версия);
	Если СтрНачинаетсяС(НРег(Значение), "v") Тогда
		Значение = Сред(Значение, 2);
	КонецЕсли;
	Возврат Значение;

КонецФункции

Функция СравнитьВерсии(Версия1, Версия2)

	К1 = РазобратьВерсию(Версия1);
	К2 = РазобратьВерсию(Версия2);

	Длина = Макс(К1.Количество(), К2.Количество());
	Для Индекс = 0 По Длина - 1 Цикл
		А = ?(Индекс < К1.Количество(), К1[Индекс], 0);
		Б = ?(Индекс < К2.Количество(), К2[Индекс], 0);
		Если А < Б Тогда
			Возврат -1;
		ИначеЕсли А > Б Тогда
			Возврат 1;
		КонецЕсли;
	КонецЦикла;
	Возврат 0;

КонецФункции

Функция РазобратьВерсию(Версия)

	Результат = Новый Массив;
	Для Каждого Часть Из СтрРазделить(Версия, ".", Ложь) Цикл
		Попытка
			Результат.Добавить(Число(Часть));
		Исключение
			Результат.Добавить(0);
		КонецПопытки;
	КонецЦикла;
	Возврат Результат;

КонецФункции

Функция ВыполнитьGETЗапросGitHub(Путь)

	Соединение = Новый HTTPСоединение("api.github.com", 443, , ,
		Новый ИнтернетПрокси(Истина), 30,
		Новый ЗащищенноеСоединениеOpenSSL());

	Запрос = Новый HTTPЗапрос(Путь);
	Запрос.Заголовки.Вставить("Accept",     "application/vnd.github+json");
	Запрос.Заголовки.Вставить("User-Agent", "http_HTTPСервер-Updater/1.0");

	Ответ = Соединение.Получить(Запрос);

	Если Ответ.КодСостояния < 200 Или Ответ.КодСостояния >= 300 Тогда
		ВызватьИсключение "GitHub API вернул " + Ответ.КодСостояния + ": "
			+ Лев(Ответ.ПолучитьТелоКакСтроку(), 500);
	КонецЕсли;

	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(Ответ.ПолучитьТелоКакСтроку());
	Результат = ПрочитатьJSON(ЧтениеJSON, Ложь);
	ЧтениеJSON.Закрыть();
	Возврат Результат;

КонецФункции

Функция СкачатьФайлПоURL(URL)

	Возврат СкачатьФайлПоURLРек(URL, 0);

КонецФункции

Функция СкачатьФайлПоURLРек(URL, Глубина)

	Если Глубина > 5 Тогда
		ВызватьИсключение "Слишком много редиректов";
	КонецЕсли;

	ЧастиURL = РазобратьURL(URL);

	ЗащSSL = Неопределено;
	Если ЧастиURL.Схема = "https" Тогда
		ЗащSSL = Новый ЗащищенноеСоединениеOpenSSL();
	КонецЕсли;

	Соединение = Новый HTTPСоединение(ЧастиURL.Хост, ЧастиURL.Порт, , ,
		Новый ИнтернетПрокси(Истина), 60, ЗащSSL);

	Запрос = Новый HTTPЗапрос(ЧастиURL.Путь);
	Запрос.Заголовки.Вставить("User-Agent", "http_HTTPСервер-Updater/1.0");
	Запрос.Заголовки.Вставить("Accept",     "*/*");

	Ответ = Соединение.Получить(Запрос);

	Если Ответ.КодСостояния = 301 Или Ответ.КодСостояния = 302
		Или Ответ.КодСостояния = 307 Или Ответ.КодСостояния = 308 Тогда
		Расположение = Ответ.Заголовки.Получить("Location");
		Если ПустаяСтрока(Расположение) Тогда
			ВызватьИсключение "Редирект без Location";
		КонецЕсли;
		Возврат СкачатьФайлПоURLРек(Расположение, Глубина + 1);
	КонецЕсли;

	Если Ответ.КодСостояния < 200 Или Ответ.КодСостояния >= 300 Тогда
		ВызватьИсключение "Скачивание вернуло " + Ответ.КодСостояния;
	КонецЕсли;

	Возврат Ответ.ПолучитьТелоКакДвоичныеДанные();

КонецФункции

Функция РазобратьURL(URL)

	Результат = Новый Структура("Схема, Хост, Порт, Путь", "https", "", 443, "/");

	Значение = URL;
	Если СтрНачинаетсяС(НРег(Значение), "https://") Тогда
		Результат.Схема = "https";
		Результат.Порт  = 443;
		Значение = Сред(Значение, 9);
	ИначеЕсли СтрНачинаетсяС(НРег(Значение), "http://") Тогда
		Результат.Схема = "http";
		Результат.Порт  = 80;
		Значение = Сред(Значение, 8);
	КонецЕсли;

	ПозицияСлеш = СтрНайти(Значение, "/");
	Если ПозицияСлеш = 0 Тогда
		Результат.Хост = Значение;
		Результат.Путь = "/";
	Иначе
		Результат.Хост = Лев(Значение, ПозицияСлеш - 1);
		Результат.Путь = Сред(Значение, ПозицияСлеш);
	КонецЕсли;

	ПозицияДвоеточия = СтрНайти(Результат.Хост, ":");
	Если ПозицияДвоеточия > 0 Тогда
		Попытка
			Результат.Порт = Число(Сред(Результат.Хост, ПозицияДвоеточия + 1));
		Исключение
			ОписаниеОшибкиИгнорируется = ОписаниеОшибки();
		КонецПопытки;
		Результат.Хост = Лев(Результат.Хост, ПозицияДвоеточия - 1);
	КонецЕсли;

	Возврат Результат;

КонецФункции

Процедура ПрименитьCFEКТекущемуРасширению(ДанныеCFE)

	УстановитьПривилегированныйРежим(Истина);

	ИмяРасширения = Метаданные.Имя;

	Отбор = Новый Структура("Имя", ИмяРасширения);
	НаборРасширений = РасширенияКонфигурации.Получить(Отбор);

	Если НаборРасширений.Количество() = 0 Тогда
		ВызватьИсключение "Не найдено расширение с именем '" + ИмяРасширения + "'";
	КонецЕсли;

	Расширение = НаборРасширений[0];
	Расширение.ПолучитьИзДанныхКонфигурацииРасширения(ДанныеCFE);
	Расширение.Записать();

КонецПроцедуры

#КонецОбласти

#КонецЕсли
