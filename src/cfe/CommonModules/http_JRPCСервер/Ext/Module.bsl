///////////////////////////////////////////////////////////////////////////////
// http_JRPCСервер
//
// Серверная часть JSON-RPC 2.0.
// Точка входа из HTTP-сервиса http_JRPC - функция ОбработатьЗапрос(),
// которая собирает параметры маршрута и передаёт управление конвейеру.
// Сам обработчик-нода конвейера - ВыполнитьJRPC(Контекст), вызывается
// конвейером на шаге 13.
///////////////////////////////////////////////////////////////////////////////

#Область ПрограммныйИнтерфейс

// Точка входа из HTTP-сервиса http_JRPC. Создаёт ПараметрыМаршрута,
// запускает конвейер. Сам конвейер вызовет ВыполнитьJRPC как обработчик.
//
// Параметры:
//  Запрос - HTTPСервисЗапрос
//
// Возвращаемое значение:
//  HTTPСервисОтвет
//
Функция ОбработатьЗапрос(Запрос) Экспорт

	ПараметрыМаршрута = http_СерверКлиентСервер.НовыйПараметрыМаршрута();
	ПараметрыМаршрута.Сервис     = "http_JRPC";
	ПараметрыМаршрута.Обработчик = "http_JRPCСервер.ВыполнитьJRPC";

	Ответ = Новый HTTPСервисОтвет(200);
	http_HTTPКонвейер.ОбработатьЗапрос(Запрос, Ответ, ПараметрыМаршрута);
	Возврат Ответ;

КонецФункции

// Обработчик-нода конвейера. К моменту вызова конвейер уже:
//  - распарсил JSON в Контекст.ТелоДанные;
//  - выполнил общую аутентификацию/авторизацию маршрута (для /jrpc/call - None).
// Здесь мы дополнительно сверяемся с per-method auth из реестра.
//
// Параметры:
//  Контекст - Структура - контекст конвейера.
//
// Возвращаемое значение:
//  Произвольный - данные для сериализации (структура или массив JSON-RPC ответов).
//
Функция ВыполнитьJRPC(Контекст) Экспорт

	ДанныеЗапрос = Контекст.ТелоДанные;

	Если ДанныеЗапрос = Неопределено Тогда
		Возврат http_JRPCСерверСлужебный.НовыйКонвертОшибки(Неопределено,
			http_JRPCСерверСлужебный.КодОшибкиПарсинг(), "Parse error");
	КонецЕсли;

	ЭтоПакетныйЗапрос = (ТипЗнч(ДанныеЗапрос) = Тип("Массив"));
	МассивВызовов = ?(ЭтоПакетныйЗапрос, ДанныеЗапрос, http_JRPCСерверСлужебный.ОдинЭлементВМассиве(ДанныеЗапрос));

	Результат = http_JRPCСерверСлужебный.ПроверитьВалидностьЗапроса(МассивВызовов);
	http_JRPCСерверСлужебный.ВыполнитьВызовы(МассивВызовов, Результат);

	Если Не ЭтоПакетныйЗапрос Тогда
		Возврат Результат[0];
	КонецЕсли;

	// Из пакетного ответа убираем Неопределено (оповещения без id)
	РезультатПакет = Новый Массив;
	Для Каждого Элемент Из Результат Цикл
		Если Элемент <> Неопределено Тогда
			РезультатПакет.Добавить(Элемент);
		КонецЕсли;
	КонецЦикла;

	// Если все вызовы - оповещения, тело ответа отсутствует
	Возврат ?(РезультатПакет.Количество() = 0, Неопределено, РезультатПакет);

КонецФункции

// Точка входа для асинхронного выполнения оповещений (без id) через фоновое задание.
//
// Параметры:
//  Вызов - Структура - вызов JSON-RPC без id.
//
Процедура ВызватьОповещение(Вызов) Экспорт

	http_JRPCСерверСлужебный.ВыполнитьМетод(Вызов);

КонецПроцедуры

#КонецОбласти
