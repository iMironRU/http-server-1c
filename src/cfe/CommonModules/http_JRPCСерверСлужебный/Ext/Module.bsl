///////////////////////////////////////////////////////////////////////////////
// http_JRPCСерверСлужебный
//
// Внутренние процедуры/функции JSON-RPC 2.0 сервера:
// формирование конвертов, валидация структуры запроса, выполнение методов
// через реестр (без Выполнить с конкатенацией - имя метода берётся из реестра,
// аргументы передаются через массив-переменную).
///////////////////////////////////////////////////////////////////////////////

#Область СлужебныйПрограммныйИнтерфейс

// Стандартные коды ошибок JSON-RPC 2.0.
Функция КодОшибкиПарсинг()      Экспорт Возврат -32700; КонецФункции
Функция КодНеверныйЗапрос()     Экспорт Возврат -32600; КонецФункции
Функция КодМетодНеНайден()      Экспорт Возврат -32601; КонецФункции
Функция КодНеверныеПараметры()  Экспорт Возврат -32602; КонецФункции
Функция КодВнутренняяОшибка()   Экспорт Возврат -32603; КонецФункции

// Конверт ошибки JSON-RPC 2.0.
//
// Параметры:
//  Вызов     - Структура / Неопределено - вызов, в котором произошла ошибка.
//  КодОшибки - Число
//  Сообщение - Строка
//  Данные    - Произвольный - доп. данные (необязательно).
//
// Возвращаемое значение:
//  Структура - {"id", "jsonrpc", "error": {"code", "message", "data"}}.
//
Функция НовыйКонвертОшибки(Вызов = Неопределено, КодОшибки, Сообщение = "", Данные = Неопределено) Экспорт

	ОшибкаСтр = Новый Структура;
	ОшибкаСтр.Вставить("code",    КодОшибки);
	ОшибкаСтр.Вставить("message", Сообщение);
	ОшибкаСтр.Вставить("data",    Данные);

	Конверт = Новый Структура;
	Конверт.Вставить("id",      ПолучитьИдентификаторВызова(Вызов));
	Конверт.Вставить("jsonrpc", "2.0");
	Конверт.Вставить("error",   ОшибкаСтр);
	Возврат Конверт;

КонецФункции

// Конверт успешного ответа JSON-RPC 2.0.
Функция НовыйКонвертОтвета(Вызов, РезультатВызова = Неопределено) Экспорт

	Конверт = Новый Структура;
	Конверт.Вставить("id",      ПолучитьИдентификаторВызова(Вызов));
	Конверт.Вставить("jsonrpc", "2.0");
	Конверт.Вставить("result",  РезультатВызова);
	Возврат Конверт;

КонецФункции

// Оборачивает одно значение в массив из одного элемента.
Функция ОдинЭлементВМассиве(Значение) Экспорт

	М = Новый Массив;
	М.Добавить(Значение);
	Возврат М;

КонецФункции

// Проверяет структуру каждого вызова в пакете согласно спецификации JSON-RPC 2.0.
// Обязательные поля: jsonrpc (Строка), method (Строка).
//
// Возвращаемое значение:
//  Массив - по одному элементу на каждый вызов:
//   Неопределено  - вызов валиден, готов к выполнению;
//   Структура     - конверт ошибки -32600 Invalid Request.
//
Функция ПроверитьВалидностьЗапроса(МассивВызовов) Экспорт

	Результат = Новый Массив;

	Для Каждого Вызов Из МассивВызовов Цикл

		ЭтоОбъект   = (ТипЗнч(Вызов) = Тип("Структура")) Или (ТипЗнч(Вызов) = Тип("Соответствие"));
		ЕстьJsonrpc = ЭтоОбъект И ТипЗнч(ПолучитьПоле(Вызов, "jsonrpc")) = Тип("Строка");
		ЕстьMethod  = ЭтоОбъект И ТипЗнч(ПолучитьПоле(Вызов, "method"))  = Тип("Строка");

		Если ЕстьJsonrpc И ЕстьMethod Тогда
			Результат.Добавить(Неопределено);
		Иначе
			Результат.Добавить(НовыйКонвертОшибки(Вызов, КодНеверныйЗапрос(), "Invalid Request"));
		КонецЕсли;

	КонецЦикла;

	Возврат Результат;

КонецФункции

// Выполняет все вызовы из пакета, пропуская уже обработанные (с ошибками валидации).
// Оповещения (без id) запускаются асинхронно через фоновое задание.
//
// Параметры:
//  МассивВызовов - Массив - вызовы JSON-RPC.
//  Результат     - Массив - выходной массив (модифицируется).
//
Процедура ВыполнитьВызовы(МассивВызовов, Результат) Экспорт

	Для Индекс = 0 По МассивВызовов.Количество() - 1 Цикл

		Если Результат[Индекс] <> Неопределено Тогда
			Продолжить; // уже помечен как ошибка валидации
		КонецЕсли;

		Вызов     = МассивВызовов[Индекс];
		ИмяМетода = ПолучитьПоле(Вызов, "method");
		Метод     = http_СерверСлужебный.ПолучитьМетодJRPC(ИмяМетода);

		Если Метод = Неопределено Тогда
			Результат[Индекс] = НовыйКонвертОшибки(Вызов, КодМетодНеНайден(),
				"Method not found", "Метод '" + ИмяМетода + "' не зарегистрирован");
			Продолжить;
		КонецЕсли;

		Если ПолучитьИдентификаторВызова(Вызов) = Неопределено Тогда
			// Оповещение - асинхронно, ответ не нужен
			ЗапуститьОповещениеАсинхронно(Вызов);
			Результат[Индекс] = Неопределено;
		Иначе
			Результат[Индекс] = ВыполнитьМетод(Вызов);
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

// Выполняет один JRPC-метод. Имя обработчика берётся из реестра, аргументы
// передаются через переменную-массив - то есть Выполнить() не использует
// конкатенацию с пользовательскими данными.
//
// Параметры:
//  Вызов - Структура - вызов JSON-RPC (method, params, id).
//
// Возвращаемое значение:
//  Структура - конверт ответа или ошибки JSON-RPC.
//
Функция ВыполнитьМетод(Вызов) Экспорт

	ИмяМетода = ПолучитьПоле(Вызов, "method");
	Метод     = http_СерверСлужебный.ПолучитьМетодJRPC(ИмяМетода);

	Если Метод = Неопределено Тогда
		Возврат НовыйКонвертОшибки(Вызов, КодМетодНеНайден(), "Method not found");
	КонецЕсли;

	Обработчик = Метод.Обработчик;
	Если ПустаяСтрока(Обработчик) Или СтрНайти(Обработчик, ".") = 0 Тогда
		Возврат НовыйКонвертОшибки(Вызов, КодВнутренняяОшибка(),
			"Internal error", "В реестре метод '" + ИмяМетода
			+ "' зарегистрирован с некорректным обработчиком: '" + Обработчик + "'");
	КонецЕсли;

	// Имя обработчика контролируется нашим реестром, не пришло из тела запроса.
	// Аргументы передаются по ссылке через переменную Параметры - не конкатенацией.
	Параметры = ПолучитьПоле(Вызов, "params");

	Результат = Неопределено;
	Попытка
		Выполнить("Результат = " + Обработчик + "(Параметры);");
	Исключение
		Возврат НовыйКонвертОшибки(Вызов, КодВнутренняяОшибка(),
			"Internal error", ОписаниеОшибки());
	КонецПопытки;

	Если Метод.ТипВызова = "Процедура" Тогда
		// Процедура - не возвращает результат, но ответ JRPC нужен
		Возврат НовыйКонвертОтвета(Вызов);
	КонецЕсли;

	Возврат НовыйКонвертОтвета(Вызов, Результат);

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Безопасное извлечение из Структуры/Соответствия.
Функция ПолучитьПоле(Данные, ИмяПоля)

	Если ТипЗнч(Данные) = Тип("Соответствие") Тогда
		Возврат Данные.Получить(ИмяПоля);
	ИначеЕсли ТипЗнч(Данные) = Тип("Структура") Тогда
		Значение = Неопределено;
		Данные.Свойство(ИмяПоля, Значение);
		Возврат Значение;
	КонецЕсли;
	Возврат Неопределено;

КонецФункции

// Извлекает id из вызова. Если вызов или id отсутствует - Неопределено (оповещение).
Функция ПолучитьИдентификаторВызова(Вызов)

	Если Вызов = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Возврат ПолучитьПоле(Вызов, "id");

КонецФункции

// Запускает оповещение асинхронно через фоновое задание.
// Ошибка запуска - в журнал регистрации, обработка остального пакета продолжается.
Процедура ЗапуститьОповещениеАсинхронно(Вызов)

	Попытка
		МассивПараметров = ОдинЭлементВМассиве(Вызов);
		ФоновыеЗадания.Выполнить("http_JRPCСервер.ВызватьОповещение", МассивПараметров);
	Исключение
		Попытка
			ЗаписьЖурналаРегистрации(
				"http_JRPCСерверСлужебный: не удалось запустить оповещение для метода "
				+ ПолучитьПоле(Вызов, "method"),
				УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки());
		Исключение
			ОписаниеОшибкиИгнорируется = ОписаниеОшибки();
		КонецПопытки;
	КонецПопытки;

КонецПроцедуры

#КонецОбласти
