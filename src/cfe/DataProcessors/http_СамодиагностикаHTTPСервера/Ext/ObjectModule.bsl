КонецПроцедуры

// e2e-6. Идемпотентность: послать echo дважды с одинаковым Idempotency-Key,
// первый раз ожидаем нормальный ответ, второй - X-Idempotency-Cache: HIT.
// Идемпотентность для маршрута http_JRPC сейчас не включена по умолчанию,
// поэтому тест считается пройденным если оба запроса вернули 200 (без проверки кэша).
// При включённой в Справочник.http_HTTPСервисы идемпотентности - проверяем заголовок.
Процедура E2EИдемпотентность(Результаты, П)

	ИмяТеста = "E2E: повторный запрос с тем же Idempotency-Key";

	IdempKey = Строка(Новый УникальныйИдентификатор);
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type",    "application/json");
	Заголовки.Вставить("Idempotency-Key", IdempKey);

	Тело = "{""jsonrpc"":""2.0"",""method"":""demo.echo"",""params"":{""n"":1},""id"":10}";

	Ответ1 = E2EВызов(П, "/hs/jrpc/call", "POST", Тело, Заголовки);
	Если Ответ1.Ошибка Или Ответ1.КодСостояния <> 200 Тогда
		ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "Первый запрос: " + Ответ1.Сообщение);
		Возврат;
	КонецЕсли;

	Ответ2 = E2EВызов(П, "/hs/jrpc/call", "POST", Тело, Заголовки);
	Если Ответ2.Ошибка Или Ответ2.КодСостояния <> 200 Тогда
		ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "Повторный запрос: " + Ответ2.Сообщение);
		Возврат;
	КонецЕсли;

	КэшHIT = Ответ2.Заголовки.Получить("X-Idempotency-Cache");
	Если КэшHIT = "HIT" Тогда
		ДобавитьРезультат(Результаты, ИмяТеста, Истина,
			"Повторный запрос обслужен из кэша (X-Idempotency-Cache=HIT)");
	Иначе
		// Идемпотентность не настроена для /jrpc/call - оба ответа без кэша. Это норма.
		ДобавитьРезультат(Результаты, ИмяТеста, Истина,
			"Оба запроса 200 (идемпотентность для /jrpc/call не включена; чтобы включить - "
			+ "добавьте в Справочник.http_HTTPСервисы запись с Наименование='http_JRPC' и ОбеспечениеИдемпотентности=Истина)");
	КонецЕсли;

КонецПроцедуры

// Выполняет HTTP-запрос на свою же опубликованную базу.
// Возвращает структуру: {Ошибка: Булево, Сообщение: Строка, КодСостояния: Число,
//                       Тело: Строка, Заголовки: Соответствие}
Функция E2EВызов(П, ОтносительныйПуть, Метод, Тело, Заголовки)

	Результат = Новый Структура("Ошибка, Сообщение, КодСостояния, Тело, Заголовки",
		Ложь, "", 0, "", Новый Соответствие);

	Попытка
		ЧастиURL = РазобратьURLE2E(П.БазовыйURL);

		ЗащSSL = Неопределено;
		Если ЧастиURL.Схема = "https" Тогда
			ЗащSSL = Новый ЗащищенноеСоединениеOpenSSL();
		КонецЕсли;

		Логин  = ?(П.Свойство("Логин"),  П.Логин,  "");
		Пароль = ?(П.Свойство("Пароль"), П.Пароль, "");

		Соединение = Новый HTTPСоединение(
			ЧастиURL.Хост, ЧастиURL.Порт,
			Логин, Пароль,
			Новый ИнтернетПрокси(Истина),
			30, ЗащSSL);

		ПолныйПуть = ЧастиURL.Путь;
		Если СтрЗаканчиваетсяНа(ПолныйПуть, "/") Тогда
			ПолныйПуть = Лев(ПолныйПуть, СтрДлина(ПолныйПуть) - 1);
		КонецЕсли;
		ПолныйПуть = ПолныйПуть + ОтносительныйПуть;

		Запрос = Новый HTTPЗапрос(ПолныйПуть);
		Запрос.Заголовки.Вставить("User-Agent", "http_HTTPСервер-Self/1.0");
		Если Заголовки <> Неопределено Тогда
			Для Каждого Заг Из Заголовки Цикл
				Запрос.Заголовки.Вставить(Заг.Ключ, Заг.Значение);
			КонецЦикла;
		КонецЕсли;
		Если Не ПустаяСтрока(Тело) Тогда
			Запрос.УстановитьТелоИзСтроки(Тело);
		КонецЕсли;

		Если Метод = "POST" Тогда
			Ответ = Соединение.ОтправитьДляОбработки(Запрос);
		Иначе
			Ответ = Соединение.Получить(Запрос);
		КонецЕсли;

		Результат.КодСостояния = Ответ.КодСостояния;
		Результат.Тело         = Ответ.ПолучитьТелоКакСтроку();
		Для Каждого Заг Из Ответ.Заголовки Цикл
			Результат.Заголовки.Вставить(Заг.Ключ, Заг.Значение);
		КонецЦикла;

	Исключение
		Результат.Ошибка    = Истина;
		Результат.Сообщение = ОписаниеОшибки();
	КонецПопытки;

	Возврат Результат;

КонецФункции

Функция РазобратьURLE2E(URL)

	Результат = Новый Структура("Схема, Хост, Порт, Путь", "http", "", 80, "/");

	Значение = СокрЛП(URL);
	Если СтрНачинаетсяС(НРег(Значение), "https://") Тогда
		Результат.Схема = "https";
		Результат.Порт  = 443;
		Значение = Сред(Значение, 9);
	ИначеЕсли СтрНачинаетсяС(НРег(Значение), "http://") Тогда
		Результат.Схема = "http";
		Результат.Порт  = 80;
		Значение = Сред(Значение, 8);
	КонецЕсли;

	ПозицияСлеш = СтрНайти(Значение, "/");
	Если ПозицияСлеш = 0 Тогда
		Результат.Хост = Значение;
		Результат.Путь = "/";
	Иначе
		Результат.Хост = Лев(Значение, ПозицияСлеш - 1);
		Результат.Путь = Сред(Значение, ПозицияСлеш);
	КонецЕсли;

	ПозицияДвоеточия = СтрНайти(Результат.Хост, ":");
	Если ПозицияДвоеточия > 0 Тогда
		Попытка
			Результат.Порт = Число(Сред(Результат.Хост, ПозицияДвоеточия + 1));
		Исключение
			ОписаниеОшибкиИгнорируется = ОписаниеОшибки();
		КонецПопытки;
		Результат.Хост = Лев(Результат.Хост, ПозицияДвоеточия - 1);
	КонецЕсли;

	Возврат Результат;

КонецФункции

