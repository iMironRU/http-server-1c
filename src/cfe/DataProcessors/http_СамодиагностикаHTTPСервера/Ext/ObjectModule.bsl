///////////////////////////////////////////////////////////////////////////////
// http_СамодиагностикаHTTPСервера (модуль объекта)
//
// Smoke-тесты ядра расширения. Вызываются из формы или напрямую через консоль.
// Тесты бьют по серверным модулям расширения (не по HTTP) - не требуют публикации.
///////////////////////////////////////////////////////////////////////////////

#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Запускает все тесты и возвращает таблицу результатов.
//
// Параметры:
//  ПараметрыE2E - Структура, Неопределено - если задано {БазовыйURL, Логин, Пароль} -
//                 после unit-тестов запускаются end-to-end через HTTPСоединение.
//
// Возвращаемое значение:
//  ТаблицаЗначений с колонками Тест, Статус, Сообщение.
//
Функция ВыполнитьВсеТесты(ПараметрыE2E = Неопределено) Экспорт

	Результаты = НоваяТаблицаРезультатов();

	// Unit-тесты по серверным модулям
	ТестРеестрJRPC(Результаты);
	ТестJRPCEcho(Результаты);
	ТестJRPCSum(Результаты);
	ТестJRPCUnknownMethod(Результаты);
	ТестSwaggerГенератор(Результаты);
	ТестНастройкиСервиса(Результаты);
	ТестАутентификацияAPIКлюч(Результаты);
	ТестАдаптерHTTPСервиса(Результаты);

	// End-to-end тесты через реальный HTTP (если задан BaseURL)
	Если ТипЗнч(ПараметрыE2E) = Тип("Структура")
		И ПараметрыE2E.Свойство("БазовыйURL")
		И Не ПустаяСтрока(ПараметрыE2E.БазовыйURL) Тогда
		E2EPing(Результаты,         ПараметрыE2E);
		E2ESwagger(Результаты,      ПараметрыE2E);
		E2EJRPCEcho(Результаты,     ПараметрыE2E);
		E2EJRPCSum(Результаты,      ПараметрыE2E);
		E2EJRPCUnknown(Результаты,  ПараметрыE2E);
		E2EИдемпотентность(Результаты, ПараметрыE2E);
	КонецЕсли;

	Возврат Результаты;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция НоваяТаблицаРезультатов()

	Т = Новый ТаблицаЗначений;
	Т.Колонки.Добавить("Тест",      Новый ОписаниеТипов("Строка"));
	Т.Колонки.Добавить("Статус",    Новый ОписаниеТипов("Строка"));
	Т.Колонки.Добавить("Сообщение", Новый ОписаниеТипов("Строка"));
	Возврат Т;

КонецФункции

Процедура ДобавитьРезультат(Результаты, ИмяТеста, Успешно, Сообщение = "")

	Строка = Результаты.Добавить();
	Строка.Тест      = ИмяТеста;
	Строка.Статус    = ?(Успешно, "ОК", "ОШИБКА");
	Строка.Сообщение = Сообщение;

КонецПроцедуры

// 1. Реестр JRPC-методов содержит demo.echo и demo.sum.
Процедура ТестРеестрJRPC(Результаты)

	ИмяТеста = "Реестр JRPC: demo.echo и demo.sum зарегистрированы";

	Попытка
		Echo = http_СерверСлужебный.ПолучитьМетодJRPC("demo.echo");
		Sum  = http_СерверСлужебный.ПолучитьМетодJRPC("demo.sum");

		Если Echo = Неопределено Или Sum = Неопределено Тогда
			ДобавитьРезультат(Результаты, ИмяТеста, Ложь,
				"Отсутствует в реестре: "
				+ ?(Echo = Неопределено, "demo.echo ", "")
				+ ?(Sum  = Неопределено, "demo.sum",  ""));
			Возврат;
		КонецЕсли;

		ДобавитьРезультат(Результаты, ИмяТеста, Истина,
			"demo.echo -> " + Echo.Обработчик + ", demo.sum -> " + Sum.Обработчик);
	Исключение
		ДобавитьРезультат(Результаты, ИмяТеста, Ложь, ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

// 2. JRPC: demo.echo возвращает params без изменений.
Процедура ТестJRPCEcho(Результаты)

	ИмяТеста = "JRPC demo.echo возвращает params";

	Попытка
		Вызов = Новый Структура("jsonrpc, method, params, id", "2.0", "demo.echo",
			Новый Структура("x, имя", 42, "Иван"), 1);

		Ответ = http_JRPCСерверСлужебный.ВыполнитьМетод(Вызов);

		Если Не Ответ.Свойство("result") Тогда
			ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "Ответ не содержит 'result': " + ОписаниеСтруктуры(Ответ));
			Возврат;
		КонецЕсли;

		X = 0;
		Ответ.result.Свойство("x", X);
		Если X <> 42 Тогда
			ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "Ожидался x=42, получено x=" + Строка(X));
			Возврат;
		КонецЕсли;

		ДобавитьРезультат(Результаты, ИмяТеста, Истина, "x=42 эхо вернулось корректно");
	Исключение
		ДобавитьРезультат(Результаты, ИмяТеста, Ложь, ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

// 3. JRPC: demo.sum [2, 3] = 5.
Процедура ТестJRPCSum(Результаты)

	ИмяТеста = "JRPC demo.sum([2,3]) = 5";

	Попытка
		Параметры = Новый Массив;
		Параметры.Добавить(2);
		Параметры.Добавить(3);

		Вызов = Новый Структура("jsonrpc, method, params, id", "2.0", "demo.sum", Параметры, 2);
		Ответ = http_JRPCСерверСлужебный.ВыполнитьМетод(Вызов);

		Если Не Ответ.Свойство("result") Тогда
			ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "Нет result: " + ОписаниеСтруктуры(Ответ));
			Возврат;
		КонецЕсли;

		Если Ответ.result <> 5 Тогда
			ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "Ожидалось 5, получено " + Строка(Ответ.result));
			Возврат;
		КонецЕсли;

		ДобавитьРезультат(Результаты, ИмяТеста, Истина, "результат = 5");
	Исключение
		ДобавитьРезультат(Результаты, ИмяТеста, Ложь, ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

// 4. JRPC: неизвестный метод -> error.code = -32601.
Процедура ТестJRPCUnknownMethod(Результаты)

	ИмяТеста = "JRPC unknown method -> -32601";

	Попытка
		Вызов = Новый Структура("jsonrpc, method, id", "2.0", "phantom.method", 3);
		Ответ = http_JRPCСерверСлужебный.ВыполнитьМетод(Вызов);

		Если Не Ответ.Свойство("error") Тогда
			ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "Должна быть ошибка, получено: " + ОписаниеСтруктуры(Ответ));
			Возврат;
		КонецЕсли;

		Если Ответ.error.code <> -32601 Тогда
			ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "Ожидался код -32601, получен " + Строка(Ответ.error.code));
			Возврат;
		КонецЕсли;

		ДобавитьРезультат(Результаты, ИмяТеста, Истина, "code=-32601, message='" + Ответ.error.message + "'");
	Исключение
		ДобавитьРезультат(Результаты, ИмяТеста, Ложь, ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

// 5. SwaggerГенератор: формирует валидный JSON.
Процедура ТестSwaggerГенератор(Результаты)

	ИмяТеста = "Swagger: генерация валидного OpenAPI 3.0";

	Попытка
		Спецификация = http_SwaggerГенератор.СформироватьOpenAPI("http://localhost/test");
		СтрокаJSON   = http_SwaggerГенератор.СпецификацияВJSON(Спецификация);

		Если ПустаяСтрока(СтрокаJSON) Тогда
			ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "Пустой JSON");
			Возврат;
		КонецЕсли;

		Если СтрНайти(СтрокаJSON, """openapi""") = 0 Тогда
			ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "В JSON нет ключа openapi");
			Возврат;
		КонецЕсли;

		Если СтрНайти(СтрокаJSON, "/jrpc/call") = 0 Тогда
			ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "В JSON нет пути /jrpc/call");
			Возврат;
		КонецЕсли;

		ДобавитьРезультат(Результаты, ИмяТеста, Истина,
			"JSON " + Строка(СтрДлина(СтрокаJSON)) + " байт, содержит ожидаемые поля");
	Исключение
		ДобавитьРезультат(Результаты, ИмяТеста, Ложь, ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

// 6. Настройки сервиса: возвращаются дефолты если в справочнике пусто.
Процедура ТестНастройкиСервиса(Результаты)

	ИмяТеста = "Настройки сервиса: дефолты для несуществующего";

	Попытка
		Настройки = Справочники.http_HTTPСервисы.НастройкиСервиса("несуществующий_сервис_" + Строка(Новый УникальныйИдентификатор));

		Если Настройки.НастройкиНайдены Тогда
			ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "НастройкиНайдены=Истина для случайного имени");
			Возврат;
		КонецЕсли;

		Если Не Настройки.Журналирование Тогда
			ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "Журналирование по умолчанию должно быть Истина");
			Возврат;
		КонецЕсли;

		ДобавитьРезультат(Результаты, ИмяТеста, Истина,
			"Дефолты применились: Журналирование=" + Настройки.Журналирование
			+ ", Идемпотентность=" + Настройки.ОбеспечениеИдемпотентности);
	Исключение
		ДобавитьРезультат(Результаты, ИмяТеста, Ложь, ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

// 7. API-ключи: создание + поиск по hash работают.
Процедура ТестАутентификацияAPIКлюч(Результаты)

	ИмяТеста = "API-ключ: создать и найти";

	Попытка
		ТекущийПользователь = ПользователиИнформационнойБазы.ТекущийПользователь();
		Если ТекущийПользователь = Неопределено Или ПустаяСтрока(ТекущийПользователь.Имя) Тогда
			ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "Нет аутентифицированного пользователя ИБ");
			Возврат;
		КонецЕсли;

		Запрос = Новый Запрос(
			"ВЫБРАТЬ ПЕРВЫЕ 1 Пользователи.Ссылка КАК Ссылка
			|ИЗ Справочник.Пользователи КАК Пользователи
			|ГДЕ Пользователи.ИдентификаторПользователяИБ = &UUID");
		Запрос.УстановитьПараметр("UUID", ТекущийПользователь.УникальныйИдентификатор);
		Выборка = Запрос.Выполнить().Выбрать();

		Если Не Выборка.Следующий() Тогда
			ДобавитьРезультат(Результаты, ИмяТеста, Ложь,
				"Текущий ПользовательИБ не связан с Справочник.Пользователи (это норма для системных пользователей)");
			Возврат;
		КонецЕсли;

		ДанныеКлюча = http_АутентификацияСлужебный.СоздатьAPIКлюч(
			"Тест Самодиагностики " + Строка(ТекущаяДатаСеанса()),
			Выборка.Ссылка,
			"Создан автотестом, можно удалить");

		Если ПустаяСтрока(ДанныеКлюча.Plaintext) Тогда
			ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "Пустой plaintext-ключ");
			Возврат;
		КонецЕсли;

		// Помечаем созданный элемент на удаление чтобы не засорять справочник
		УстановитьПривилегированныйРежим(Истина);
		Объект = ДанныеКлюча.Ссылка.ПолучитьОбъект();
		Объект.УстановитьПометкуУдаления(Истина);

		ДобавитьРезультат(Результаты, ИмяТеста, Истина,
			"Ключ создан (длина plaintext=" + Строка(СтрДлина(ДанныеКлюча.Plaintext)) + "), элемент помечен на удаление");
	Исключение
		ДобавитьРезультат(Результаты, ИмяТеста, Ложь, ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

// 8. Адаптер: смок-тест на HTTPСервисОтвет (как ставит/читает код).
Процедура ТестАдаптерHTTPСервиса(Результаты)

	ИмяТеста = "Адаптер HTTPСервисОтвет: установка/чтение кода";

	Попытка
		Ответ = Новый HTTPСервисОтвет(200);
		http_АдаптерЗапросОтветСлужебный.ОтветУстановитьКод(Ответ, 418);

		Код = http_АдаптерЗапросОтветСлужебный.ОтветПолучитьКод(Ответ);
		Если Код <> 418 Тогда
			ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "Ожидался 418, получен " + Строка(Код));
			Возврат;
		КонецЕсли;

		http_АдаптерЗапросОтветСлужебный.ОтветУстановитьЗаголовок(Ответ, "X-Test", "OK");
		Если Ответ.Заголовки.Получить("X-Test") <> "OK" Тогда
			ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "Заголовок X-Test не установлен");
			Возврат;
		КонецЕсли;

		ДобавитьРезультат(Результаты, ИмяТеста, Истина, "код 418, заголовок X-Test=OK");
	Исключение
		ДобавитьРезультат(Результаты, ИмяТеста, Ложь, ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

Функция ОписаниеСтруктуры(Структура)

	Попытка
		Запись = Новый ЗаписьJSON;
		Запись.УстановитьСтроку();
		ЗаписатьJSON(Запись, Структура);
		Возврат Запись.Закрыть();
	Исключение
		Возврат "<не сериализуется>";
	КонецПопытки;

КонецФункции

#Область E2EТесты

// e2e-1. GET /hs/http/ping -> 200 "Пинг-Понг"
Процедура E2EPing(Результаты, П)

	ИмяТеста = "E2E: GET /hs/http/ping -> 200 'Пинг-Понг'";

	Ответ = E2EВызов(П, "/hs/http/ping", "GET", "", Неопределено);
	Если Ответ.Ошибка Тогда
		ДобавитьРезультат(Результаты, ИмяТеста, Ложь, Ответ.Сообщение);
		Возврат;
	КонецЕсли;
	Если Ответ.КодСостояния <> 200 Тогда
		ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "Код " + Ответ.КодСостояния + ": " + Лев(Ответ.Тело, 200));
		Возврат;
	КонецЕсли;
	Если СтрНайти(Ответ.Тело, "Пинг") = 0 Тогда
		ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "В теле нет 'Пинг': " + Лев(Ответ.Тело, 200));
		Возврат;
	КонецЕсли;
	ДобавитьРезультат(Результаты, ИмяТеста, Истина, "200 - " + Ответ.Тело);

КонецПроцедуры

// e2e-2. GET /hs/swagger/swagger.json -> 200, валидный JSON
Процедура E2ESwagger(Результаты, П)

	ИмяТеста = "E2E: GET /hs/swagger/swagger.json -> валидный OpenAPI";

	Ответ = E2EВызов(П, "/hs/swagger/swagger.json", "GET", "", Неопределено);
	Если Ответ.Ошибка Тогда
		ДобавитьРезультат(Результаты, ИмяТеста, Ложь, Ответ.Сообщение);
		Возврат;
	КонецЕсли;
	Если Ответ.КодСостояния <> 200 Тогда
		ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "Код " + Ответ.КодСостояния + ": " + Лев(Ответ.Тело, 200));
		Возврат;
	КонецЕсли;
	Если СтрНайти(Ответ.Тело, """openapi""") = 0 Тогда
		ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "Нет 'openapi' в теле: " + Лев(Ответ.Тело, 200));
		Возврат;
	КонецЕсли;
	ДобавитьРезультат(Результаты, ИмяТеста, Истина,
		"200 - JSON " + Строка(СтрДлина(Ответ.Тело)) + " байт");

КонецПроцедуры

// e2e-3. POST /hs/jrpc/call demo.echo -> result.x = 42
Процедура E2EJRPCEcho(Результаты, П)

	ИмяТеста = "E2E: JRPC demo.echo через HTTP";

	Тело = "{""jsonrpc"":""2.0"",""method"":""demo.echo"",""params"":{""x"":42},""id"":1}";
	ЗаголовкиЗапроса = Новый Соответствие;
	ЗаголовкиЗапроса.Вставить("Content-Type", "application/json");
	Ответ = E2EВызов(П, "/hs/jrpc/call", "POST", Тело, ЗаголовкиЗапроса);
	Если Ответ.Ошибка Тогда
		ДобавитьРезультат(Результаты, ИмяТеста, Ложь, Ответ.Сообщение);
		Возврат;
	КонецЕсли;
	Если Ответ.КодСостояния <> 200 Тогда
		ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "Код " + Ответ.КодСостояния);
		Возврат;
	КонецЕсли;
	Если СтрНайти(СтрЗаменить(Ответ.Тело, " ", ""), """x"":42") = 0 Тогда
		ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "Нет 'x':42: " + Лев(Ответ.Тело, 200));
		Возврат;
	КонецЕсли;
	ДобавитьРезультат(Результаты, ИмяТеста, Истина, "200 - x=42 эхо");

КонецПроцедуры

// e2e-4. POST /hs/jrpc/call demo.sum [2,3] -> result = 5
Процедура E2EJRPCSum(Результаты, П)

	ИмяТеста = "E2E: JRPC demo.sum через HTTP";

	Тело = "{""jsonrpc"":""2.0"",""method"":""demo.sum"",""params"":[2,3],""id"":2}";
	ЗаголовкиЗапроса = Новый Соответствие;
	ЗаголовкиЗапроса.Вставить("Content-Type", "application/json");
	Ответ = E2EВызов(П, "/hs/jrpc/call", "POST", Тело, ЗаголовкиЗапроса);
	Если Ответ.Ошибка Тогда
		ДобавитьРезультат(Результаты, ИмяТеста, Ложь, Ответ.Сообщение);
		Возврат;
	КонецЕсли;
	Если СтрНайти(СтрЗаменить(Ответ.Тело, " ", ""), """result"":5") = 0 Тогда
		ДобавитьРезультат(Результаты, ИмяТеста, Ложь, "Нет result=5: " + Лев(Ответ.Тело, 200));
		Возврат;
	КонецЕсли;
	ДобавитьРезультат(Результаты, ИмяТеста, Истина, "200 - 2+3=5");

КонецПроцедуры

// e2e-5. POST /hs/jrpc/call unknown -> error.code = -32601
Процедура E2EJRPCUnknown(Результаты, П)

	ИмяТеста = "E2E: JRPC unknown method -> -32601";

	Тело = "{""jsonrpc"":""2.0"",""method"":""phantom.method"",""id"":3}";
