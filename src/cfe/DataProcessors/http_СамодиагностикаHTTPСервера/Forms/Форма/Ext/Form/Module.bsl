#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриОткрытии(Отказ)

	ТекущаяВерсия = http_АвтообновлениеСлужебный.ВерсияРасширения();

	// Снимаем безопасный режим автоматически — он включается при первой установке
	// и после каждого применения cfe через API
	http_АвтообновлениеСлужебный.СнятьБезопасныйРежим();

	// Авто-заполнение URL из констант БСП (интернет → локальная сеть)
	Если ПустаяСтрока(БазовыйURL) Тогда
		БазовыйURL = ОпределитьБазовыйURLСервера();
	КонецЕсли;

	// Авто-заполнение логина текущим пользователем
	Если ПустаяСтрока(Логин) Тогда
		Логин = ИмяПользователяИнформационнойБазы();
	КонецЕсли;

	// Восстановление сохранённого пароля
	СохранённыйПароль = ХранилищеНастроек.Загрузить(
		"http_СамодиагностикаHTTPСервера", "E2EПароль",
		Неопределено, ИмяПользователяИнформационнойБазы());
	Если ТипЗнч(СохранённыйПароль) = Тип("Строка") Тогда
		Пароль = СохранённыйПароль;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	СохранитьПарольНаСервере(Пароль);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗапуститьТесты(Команда)

	ЗапуститьТестыНаСервере();

КонецПроцедуры

&НаКлиенте
Процедура ПроверитьОбновление(Команда)

	Информация = ПолучитьИнформациюОПоследнемРелизеНаСервере();

	Если Не Информация.Успех Тогда
		ПоказатьПредупреждение(, Информация.Сообщение);
		Возврат;
	КонецЕсли;

	Если Не Информация.ЕстьОбновление Тогда
		ПоказатьПредупреждение(,
			"У вас уже последняя версия (" + Информация.ТекущаяВерсия + ")");
		Возврат;
	КонецЕсли;

	Если ПустаяСтрока(Информация.URLФайла) Тогда
		ПоказатьПредупреждение(,
			"Доступна новая версия " + Информация.НоваяВерсия
			+ ", но в релизе нет .cfe-файла");
		Возврат;
	КонецЕсли;

	Текст = "Доступна новая версия " + Информация.НоваяВерсия
		+ " (текущая " + Информация.ТекущаяВерсия + "). Установить?";
	ДанныеДляОбратногоВызова = Новый Структура("URLФайла", Информация.URLФайла);
	Оповещение = Новый ОписаниеОповещения(
		"ПроверитьОбновлениеЗавершение", ЭтотОбъект, ДанныеДляОбратногоВызова);
	ПоказатьВопрос(Оповещение, Текст, РежимДиалогаВопрос.ДаНет);

КонецПроцедуры

&НаКлиенте
Процедура ПроверитьОбновлениеЗавершение(Результат, ДополнительныеПараметры) Экспорт

	Если Результат <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;

	ИтогУстановки = УстановитьОбновлениеНаСервере(ДополнительныеПараметры.URLФайла);
	ПоказатьПредупреждение(, ИтогУстановки.Сообщение);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗапуститьТестыНаСервере()

	ТаблицаРезультатов.Очистить();

	ПараметрыE2E = Неопределено;
	Если Не ПустаяСтрока(БазовыйURL) Тогда
		ПараметрыE2E = Новый Структура;
		ПараметрыE2E.Вставить("БазовыйURL", БазовыйURL);
		ПараметрыE2E.Вставить("Логин",      Логин);
		ПараметрыE2E.Вставить("Пароль",     Пароль);
	КонецЕсли;

	Результаты = РеквизитФормыВЗначение("Объект").ВыполнитьВсеТесты(ПараметрыE2E);

	Для Каждого Строка Из Результаты Цикл
		НоваяСтрока = ТаблицаРезультатов.Добавить();
		НоваяСтрока.Тест      = Строка.Тест;
		НоваяСтрока.Статус    = Строка.Статус;
		НоваяСтрока.Сообщение = Строка.Сообщение;
	КонецЦикла;

КонецПроцедуры

&НаСервере
Функция ПолучитьИнформациюОПоследнемРелизеНаСервере()

	Возврат http_АвтообновлениеСлужебный.ПолучитьИнформациюОПоследнемРелизе();

КонецФункции

&НаСервере
Функция УстановитьОбновлениеНаСервере(URLФайла)

	Возврат http_АвтообновлениеСлужебный.УстановитьОбновлениеИзРелиза(URLФайла);

КонецФункции

&НаСервере
Функция ОпределитьБазовыйURLСервера()

	Попытка
		URLИнтернет = СокрЛП(Константы.АдресПубликацииИнформационнойБазыВИнтернете.Получить());
		Если Не ПустаяСтрока(URLИнтернет) Тогда
			Возврат URLИнтернет;
		КонецЕсли;
	Исключение
	КонецПопытки;

	Попытка
		URLЛокальный = СокрЛП(Константы.АдресПубликацииИнформационнойБазыВЛокальнойСети.Получить());
		Если Не ПустаяСтрока(URLЛокальный) Тогда
			Возврат URLЛокальный;
		КонецЕсли;
	Исключение
	КонецПопытки;

	Возврат "";

КонецФункции

&НаСервере
Процедура СохранитьПарольНаСервере(ЗначениеПароля)

	ХранилищеНастроек.Сохранить(
		"http_СамодиагностикаHTTPСервера", "E2EПароль",
		ЗначениеПароля, , ИмяПользователяИнформационнойБазы());

КонецПроцедуры

#КонецОбласти
