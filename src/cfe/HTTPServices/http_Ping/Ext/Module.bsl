// Health-check endpoint расширения http_HTTPСервер.
// URL: /<base>/hs/http/ping -> 200 text/plain "Пинг-Понг".
// Заодно служит smoke-тестом всего конвейера.

Функция PingGet(Запрос)

	ПараметрыМаршрута = http_СерверКлиентСервер.НовыйПараметрыМаршрута();
	ПараметрыМаршрута.ФорматОтвета = "PlainText";
	ПараметрыМаршрута.Сервис       = "http_Ping";
	ПараметрыМаршрута.Обработчик   = "http_HTTPКонвейер.ВстроенныйОбработчикПинг";

	Ответ = Новый HTTPСервисОтвет(200);
	http_HTTPКонвейер.ОбработатьЗапрос(Запрос, Ответ, ПараметрыМаршрута);
	Возврат Ответ;

КонецФункции
